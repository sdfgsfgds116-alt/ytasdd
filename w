		-- Returns { SetValue, SetMin, SetMax, SetStep, SetTitle, SetDesc }
		-- ═══════════════════════════════════════════════════════════════════
		function Func:NumberStepper(p)
			local Title    = p.Title    or 'Value'
			local Desc     = p.Desc     or ''
			local Image    = p.Image    or ''
			local Min      = p.Min      or 0
			local Max      = p.Max      or 100
			local Step     = p.Step     or 1
			local Value    = p.Value    or Min
			local Rounding = p.Rounding or 0
			local Callback = p.Callback or function() end

			local Stepper, Config = background(ScrollingFrame_1, Title, Desc, Image, 'Slider')
			Config:SetTextTransparencyTitle(0)
			Config:SetSizeT(180)

			local RF = Instance.new("Frame", Stepper)
			RF.Name = "F"
			RF.AnchorPoint = Vector2.new(1, 0.5)
			RF.BackgroundTransparency = 1
			RF.BorderSizePixel = 0
			RF.Position = UDim2.new(1, 0, 0.5, 0)
			RF.Size = UDim2.new(0, 175, 0.8, 0)
			local RFL = Instance.new("UIListLayout", RF)
			RFL.FillDirection = Enum.FillDirection.Horizontal
			RFL.HorizontalAlignment = Enum.HorizontalAlignment.Right
			RFL.VerticalAlignment = Enum.VerticalAlignment.Center
			RFL.SortOrder = Enum.SortOrder.LayoutOrder
			RFL.Padding = UDim.new(0, 5)
			local RFP = Instance.new("UIPadding", RF)
			RFP.PaddingRight = UDim.new(0, 13)

			-- Helper: styled small button
			local function makeBtn(label, order)
				local BtnF = Instance.new("Frame", RF)
				BtnF.BackgroundColor3 = Color3.fromRGB(44, 34, 103)
				BtnF.BorderSizePixel = 0
				BtnF.Size = UDim2.new(0, 22, 0, 22)
				BtnF.LayoutOrder = order
				addToTheme('Function.Slider.Slider Bar Value', BtnF)
				Instance.new("UICorner", BtnF).CornerRadius = UDim.new(0, 6)
				local BtnL = Instance.new("TextLabel", BtnF)
				BtnL.Size = UDim2.new(1, 0, 1, 0)
				BtnL.BackgroundTransparency = 1
				BtnL.BorderSizePixel = 0
				BtnL.Font = Enum.Font.GothamBold
				BtnL.Text = label
				BtnL.TextColor3 = Color3.fromRGB(255, 255, 255)
				BtnL.TextSize = 14
				local BtnClick = click(BtnF)
				return BtnF, BtnClick, BtnL
			end

			-- Value display
			local ValF = Instance.new("Frame", RF)
			ValF.BackgroundColor3 = Color3.fromRGB(24, 24, 31)
			ValF.BorderSizePixel = 0
			ValF.Size = UDim2.new(0, 56, 0, 22)
			ValF.LayoutOrder = 2
			addToTheme('Function.Slider.Value Background', ValF)
			Instance.new("UICorner", ValF).CornerRadius = UDim.new(0, 5)
			local ValStroke = Instance.new("UIStroke", ValF)
			ValStroke.Thickness = 1; ValStroke.Transparency = 0.92
			addToTheme('Function.Slider.Value Stroke', ValStroke)
			local ValTB = Instance.new("TextBox", ValF)
			ValTB.Size = UDim2.new(1, 0, 1, 0)
			ValTB.BackgroundTransparency = 1
			ValTB.BorderSizePixel = 0
			ValTB.Font = Enum.Font.GothamBold
			ValTB.TextSize = 11
			ValTB.TextColor3 = Color3.fromRGB(255, 255, 255)
			ValTB.Text = tostring(Value)
			addToTheme('Text & Icon', ValTB)

			local _, MinusClick, _ = makeBtn("-", 1)
			local _, PlusClick, _  = makeBtn("+", 3)

			local function roundVal(v)
				local f = 10 ^ Rounding
				return math.floor(v * f + 0.5) / f
			end

			local function setVal(v)
				Value = math.clamp(roundVal(v), Min, Max)
				ValTB.Text = tostring(Value)
				pcall(Callback, Value)
			end

			MinusClick.MouseButton1Click:Connect(function()
				setVal(Value - Step)
				tw({v = ValF, t = 0.08, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0, 52, 0, 20)}}):Play()
				delay(0.08, function() tw({v = ValF, t = 0.08, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0, 56, 0, 22)}}):Play() end)
			end)
			PlusClick.MouseButton1Click:Connect(function()
				setVal(Value + Step)
				tw({v = ValF, t = 0.08, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0, 60, 0, 24)}}):Play()
				delay(0.08, function() tw({v = ValF, t = 0.08, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0, 56, 0, 22)}}):Play() end)
			end)
			ValTB.FocusLost:Connect(function()
				local n = tonumber(ValTB.Text)
				if n then setVal(n) else ValTB.Text = tostring(Value) end
			end)

			-- Hold-to-repeat support
			local function holdRepeat(btn, dir)
				local holding = false
				btn.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then
						holding = true
						task.delay(0.4, function()
							while holding do
								setVal(Value + dir * Step)
								task.wait(0.08)
							end
						end)
					end
				end)
				btn.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then holding = false end
				end)
			end
			holdRepeat(MinusClick, -1)
			holdRepeat(PlusClick, 1)

			setVal(Value)

			local New = {}
			function New:SetValue(v) setVal(v) end
			function New:SetMin(v) Min = v end
			function New:SetMax(v) Max = v end
			function New:SetStep(v) Step = v end
			function New:SetTitle(t) Config:SetTitle(t) end
			function New:SetDesc(t) Config:SetDesc(t) end
			function New:SetVisible(t) Stepper.Parent.Visible = t end
			return New
		end

