            end
            -- If none exists, request one once after a short grace period
            if not car and not spawnRequested and (tick() - findStart > 0.22) then
                spawnRequested = true
                coroutine.wrap(function()
                    PL_LocTP(buttonPivot)
                    workspace.Remote.ItemHandler:InvokeServer(carButton)
                end)()
            end
        until car or (tick() - findStart > 0.85)

        if not car then
            PL_LocTP(lastPos)
            PL_Notif("Car Go Fling", "No car found fast enough")
            return
        end

        car.Name = "DONOTUSECAR"
        repeat task.wait() until car:FindFirstChild("RWD") and car:FindFirstChild("Body") and car.Body:FindFirstChild("VehicleSeat")

        -- Sit as driver (ultra short timeout to beat instant-delete cleanup)
        local sitTimeout = tick() + 0.6
        repeat
            RunService.Heartbeat:Wait()
            myChar = LocalPlayer.Character
            myHum  = myChar and myChar:FindFirstChildOfClass("Humanoid")
            myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if myHum and myRoot then
                myRoot.CFrame = CFrame.new(car.Body.VehicleSeat.Position)
                car.Body.VehicleSeat:Sit(myHum)
            end
        until (myHum and myHum.Sit) or tick() - sitTimeout >= 0

        if not (myHum and myHum.Sit) then
            car.Name = "Car"
            PL_LocTP(lastPos)
            PL_Notif("Car Go Fling", "Failed to sit in car")
            return
        end

        -- Pick a front-facing car part (fallbacks keep it compatible across car models)
        local frontPart = car.Body:FindFirstChild("Bumper") or car.Body:FindFirstChild("Front") or
                         car.Body:FindFirstChild("Hood") or car:FindFirstChild("RWD") or car.Body.VehicleSeat
        local primary = car:FindFirstChild("RWD") or frontPart
        if not primary then
            PL_LAction("unsit", true)
            car.Name = "Car"
            PL_LocTP(lastPos)
            PL_Notif("Car Go Fling", "Car missing primary part")
            return
        end
        car.PrimaryPart = primary

        -- Instant contact-first strike: touch target immediately, then shove for 2-3 frames
        local burstForce = 26000
        local upForce = 15
        local tChar = targetPlayer.Character
        targetRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
        targetHum  = tChar and tChar:FindFirstChildOfClass("Humanoid")
        if not (targetRoot and targetHum and targetHum.Health > 0) then
            PL_LAction("unsit", true)
            car.Name = "Car"
            PL_LocTP(lastPos)
            PL_Notif("Car Go Fling", "Target moved/invalid")
            return
        end

        local pingLead = math.clamp(PL_CPing() * 12, 0.002, 0.04)
        local targetPos = targetRoot.Position + (targetRoot.AssemblyLinearVelocity * pingLead)

        local fromCar = targetPos - car.PrimaryPart.Position
        local dashDir = fromCar.Magnitude > 0 and fromCar.Unit or targetRoot.CFrame.LookVector
        if dashDir.Magnitude < 0.1 then dashDir = Vector3.new(0, 0, -1) end
        dashDir = Vector3.new(dashDir.X, 0, dashDir.Z)
        if dashDir.Magnitude < 0.1 then dashDir = Vector3.new(0, 0, -1) end
        dashDir = dashDir.Unit

        -- Keep exactly on target Y so contact is horizontal, never from above
        local y = targetPos.Y
        local targetFlat = Vector3.new(targetPos.X, y, targetPos.Z)
        local contactPos = targetFlat - (dashDir * 0.18)
        local throughPos = targetFlat + (dashDir * 1.25)

        -- Frame 1: immediate hard contact (front overlaps target body right away)
        car:SetPrimaryPartCFrame(CFrame.lookAt(contactPos, throughPos))
        if frontPart and frontPart:IsA("BasePart") then
            pcall(function()
                frontPart.AssemblyLinearVelocity = dashDir * (burstForce * 1.2) + Vector3.new(0, upForce, 0)
                frontPart.AssemblyAngularVelocity = Vector3.new(0, 2200, 0)
            end)
        end
        if car.PrimaryPart and car.PrimaryPart:IsA("BasePart") then
            pcall(function()
                car.PrimaryPart.AssemblyLinearVelocity = dashDir * (burstForce * 1.3) + Vector3.new(0, upForce, 0)
                car.PrimaryPart.AssemblyAngularVelocity = Vector3.new(0, 2400, 0)
            end)
        end

        RunService.Stepped:Wait()

        -- Frames 2-3: tiny straight-through lock so deletion still leaves a valid hit
        for i = 1, 2 do
            local tNow = targetPlayer.Character
            local rNow = tNow and tNow:FindFirstChild("HumanoidRootPart")
            local hNow = tNow and tNow:FindFirstChildOfClass("Humanoid")
            if not (rNow and hNow and hNow.Health > 0) then break end
            local pNow = rNow.Position + (rNow.AssemblyLinearVelocity * 0.01)
            local pFlat = Vector3.new(pNow.X, pNow.Y, pNow.Z)
            local passPos = pFlat + (dashDir * (0.45 + i * 0.4))
            car:SetPrimaryPartCFrame(CFrame.lookAt(passPos, passPos + dashDir * 6))
            if frontPart and frontPart:IsA("BasePart") then
                pcall(function()
                    frontPart.AssemblyLinearVelocity = dashDir * (burstForce * 1.35) + Vector3.new(0, upForce, 0)
                end)
            end
            if car.PrimaryPart and car.PrimaryPart:IsA("BasePart") then
                pcall(function()
                    car.PrimaryPart.AssemblyLinearVelocity = dashDir * (burstForce * 1.5) + Vector3.new(0, upForce, 0)
                end)
            end
            RunService.Stepped:Wait()
        end
        RunService.Heartbeat:Wait()

        task.wait(0.05)
        PL_LAction("unsit", true)
        car.Name = "Car"
        PL_LocTP(lastPos)
        PL_Notif("Car Go Fling", "Slammed " .. targetPlayer.Name)
    end)

    if not success then
        warn("[PL_CarGoFling Error]", err)
        PL_Notif("Error", "Car Go Fling failed: " .. tostring(err))
    end
end

-- ============================================================================
-- Multi-Target Car Action (Void / CarFling / Trap) — single car motion
-- ============================================================================
-- Split into helper functions to stay within Lua's 200-local-register limit.

-- Helper: chase one target until seated; returns true if seated, false otherwise.
-- Reduces locals in the main pcall scope by moving the chase loop here.
local function PL_MultiCarAction_ChaseTarget(Car, target, idx, totalTargets)
    local VChar  = target.Character
    local VHuman = VChar and VChar:FindFirstChildOfClass("Humanoid")
    local VRoot  = VChar and VChar:FindFirstChild("HumanoidRootPart")

    if not (VChar and VHuman and VRoot and VHuman.Health > 0) then return false end

    -- Find a free passenger seat for this target
    local TargetSeat = nil
    for _, v in pairs(Car.Body:GetChildren()) do
        if v:IsA("Seat") and not v.Occupant then
            TargetSeat = v; break
        end
    end
    if not TargetSeat then
        PL_Notif("Multi-Action", "No free seat for target " .. idx); return false
    end

    PL_Notif("Multi-Action", "Chasing " .. target.Name .. " (" .. idx .. "/" .. totalTargets .. ")")

    local Timeout = tick() + 20
    local CarSpin = false
    local SpinRad = 0

    task.spawn(function()
        Car.PrimaryPart = TargetSeat
        Car:SetPrimaryPartCFrame(VRoot.CFrame * CFrame.new(0, -0.3, 0))
        task.wait(4)
        CarSpin = true
    end)

    local LHuman, LHumanSit
    repeat
        task.wait()
        LHuman = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        LHumanSit = LHuman and LHuman.Sit
        VChar  = target.Character
        VHuman = VChar and VChar:FindFirstChildOfClass("Humanoid")
        VRoot  = VChar and VChar:FindFirstChild("HumanoidRootPart")

        if VRoot then
            if TargetSeat.Occupant and not (VHuman and VHuman.Sit) then
                for _, v in pairs(Car.Body:GetChildren()) do
                    if v:IsA("Seat") and not v.Occupant then
                        TargetSeat = v; break
                    end
                end
            end
            Car.PrimaryPart = TargetSeat
            local step1    = PL_CPing() / 8
            local Movement = Vector3.new(VRoot.Velocity.X, 0, VRoot.Velocity.Z)
            local Predict  = (VRoot.CFrame - (Vector3.new(0, 0, -0.1) * step1))
                           + (Movement * (step1 * 28))
            if Predict.Position.Y > 1 then
                if CarSpin then
                    SpinRad = SpinRad + 30
                    Car:SetPrimaryPartCFrame(Predict * CFrame.Angles(0, math.rad(SpinRad), 0))
                else
                    Car:SetPrimaryPartCFrame(Predict)
                end
            end
        end

        if not target.Character or target.TeamColor == BrickColor.new("Medium stone grey") then
            break
        end
    until not LHumanSit
          or (VHuman and VHuman.Sit)
          or tick() - Timeout >= 0

    -- Return: still in car?, target seated?
    LHuman = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    local stillInCar = LHuman and LHuman.Sit
    VHuman = target.Character and target.Character:FindFirstChildOfClass("Humanoid")
    return stillInCar, (VHuman and VHuman.Sit)
end

-- Helper: acquire a free car from the container (spawns one if needed).
local function PL_MultiCarAction_GetCar(neededSeats)
    local Car = nil
    local CarButton = workspace.Prison_ITEMS.buttons["Car Spawner"]["Car Spawner"]
    local ButtonPivot = CarButton:GetPivot()
    repeat
        task.wait()
        for _, v in pairs(workspace.CarContainer:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("Body") and
               v.Body:FindFirstChild("VehicleSeat") and
               v.Name ~= "DONOTUSECAR" and not v.Body.VehicleSeat.Occupant then
                local freeSeats = 0
                for _, vv in pairs(v.Body:GetChildren()) do
                    if vv:IsA("Seat") and not vv.Occupant then freeSeats += 1 end
                end
                if freeSeats >= neededSeats then
                    Car = v; break
                end
            end
        end
        if not Car then
            coroutine.wrap(function()
                PL_LocTP(ButtonPivot)
                workspace.Remote.ItemHandler:InvokeServer(CarButton)
            end)()
        end
    until Car
    return Car
end

-- Seats up to 3 targets onto ONE car before executing the final action.
-- Flow: get car → sit → chase Target1 until seated → immediately drive to
--       Target2 until seated → (Target3 if any) → execute action (void/fling/trap)
local function PL_MultiCarAction(targets, actionType)
    local success, err = pcall(function()
        local myChar = LocalPlayer.Character
        if not (myChar and myChar:FindFirstChild("HumanoidRootPart")) then
            PL_Notif("Multi-Action", "Your character not ready"); return
        end

        -- Filter to valid, alive, non-neutral targets (max 3)
        local validTargets = {}
        for _, pl in ipairs(targets) do
            if pl and pl ~= LocalPlayer and pl.Character and
               pl.TeamColor ~= BrickColor.new("Medium stone grey") then
                local h = pl.Character:FindFirstChildOfClass("Humanoid")
                if h and h.Health > 0 then
                    validTargets[#validTargets + 1] = pl
                    if #validTargets == 3 then break end
                end
            end
        end

        if #validTargets == 0 then
            PL_Notif("Multi-Action", "No valid targets selected"); return
        end

        local LHuman = myChar:FindFirstChildOfClass("Humanoid")
        if LHuman and LHuman.Sit then PL_LAction("unsit", true) end

        local LastPos = myChar.HumanoidRootPart.CFrame

        -- ── Step 1: Acquire car ───────────────────────────────────────────────
        local Car = PL_MultiCarAction_GetCar(#validTargets)
        Car.Name = "DONOTUSECAR"
        repeat task.wait() until Car:FindFirstChild("RWD") and
                                 Car:FindFirstChild("Body") and
                                 Car.Body:FindFirstChild("VehicleSeat")

        -- ── Step 2: Sit in the driver seat ───────────────────────────────────
        LHuman = myChar:FindFirstChildOfClass("Humanoid")
        local LRoot = myChar:FindFirstChild("HumanoidRootPart")
        local seatTimeout = tick() + 8

        repeat
            task.wait()
            LHuman = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            LRoot  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if LHuman and LRoot then
                LRoot.CFrame = CFrame.new(Car.Body.VehicleSeat.Position)
                Car.Body.VehicleSeat:Sit(LHuman)
            end
        until (LHuman and LHuman.Sit) or tick() - seatTimeout >= 0

        if not (LHuman and LHuman.Sit) then
            PL_LAction("unsit", true); PL_LocTP(LastPos)
            Car.Name = "Car"
            PL_Notif("Multi-Action", "Failed to sit in car"); return
        end

        -- ── Step 3: Chase each target via helper ─────────────────────────────
        local seatedCount = 0
        for idx, target in ipairs(validTargets) do
            if not (target and target.Character) then
                PL_Notif("Multi-Action", "Target " .. idx .. " gone, skipping"); continue
            end

            local stillInCar, targetSeated = PL_MultiCarAction_ChaseTarget(Car, target, idx, #validTargets)

            if not stillInCar then
                PL_LocTP(LastPos)
                PL_Notif("Multi-Action", "Lost seat — aborting"); return
            end

            if targetSeated then
                seatedCount += 1
                PL_Notif("Multi-Action", target.Name .. " seated! (" .. seatedCount .. "/" .. #validTargets .. ")")
            else
                PL_Notif("Multi-Action", target.Name .. " missed — continuing")
            end
        end

        if seatedCount == 0 then
            PL_LAction("unsit", true); PL_LocTP(LastPos)
            PL_Notif("Multi-Action", "No targets were seated — aborting"); return
        end

        -- ── Step 4: Execute the final action ─────────────────────────────────
        Car.PrimaryPart = Car:FindFirstChild("RWD")

        if actionType == "void" then
            Car:SetPrimaryPartCFrame(CFrame.new(0, 9e9, 0))
        elseif actionType == "trap" then
            Car:SetPrimaryPartCFrame(PLFeatures_Teleports.trapbuilding)
        elseif actionType == "carfling" then
            Car:SetPrimaryPartCFrame(CFrame.new(0, 9e9, 0))
        end

        task.wait(0.5)

        pcall(function()
            if LocalPlayer.TeamColor == BrickColor.new("Bright blue") then
                workspace.Remote.TeamEvent:FireServer("Bright blue")
            else
                workspace.Remote.TeamEvent:FireServer("Bright orange")
            end
        end)

        LocalPlayer.CharacterAdded:Wait()
        task.wait(0.5)
        PL_LocTP(LastPos)

        local label = actionType == "void" and "voided" or actionType == "trap" and "trapped" or "flung"
        PL_Notif("Multi-Action", seatedCount .. " player(s) " .. label .. "!")
    end)

    if not success then
        warn("[PL_MultiCarAction Error]", err)
        PL_Notif("Error", "Multi-action failed: " .. tostring(err))
    end
end

-- ============================================================================
-- Loop System
-- ============================================================================
task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            -- Loop Trapped
            if next(PLFeatures_Loops.Trapped) then
                for userId, player in next, PLFeatures_Loops.Trapped do
                    if player and player.Character and player.Character:FindFirstChild("Humanoid") and 
                       player.Character:FindFirstChild("HumanoidRootPart") then
                        if not (player.Character.Humanoid.Health == 0 or 
                                player.Character.Humanoid.Sit or 
                                player.TeamColor.Name == "Medium stone grey") then
                            if (player.Character.HumanoidRootPart.Position - PLFeatures_Teleports.trapbuilding.Position).Magnitude > 90 then
                                PLFeatures_SavedPositions.TrapPlayerPos = PLFeatures_SavedPositions.TrapPlayerPos or 
                                    LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame
                                PL_BringPL(player, PLFeatures_Teleports.trapbuilding, true)
                            end
                        end
                    end
                end
                
                if PLFeatures_SavedPositions.TrapPlayerPos then
                    wait(0.2)
                    PL_LAction("unsit", true)
                    PL_LocTP(PLFeatures_SavedPositions.TrapPlayerPos)
                    PLFeatures_SavedPositions.TrapPlayerPos = nil
                end
            end
            
            -- Loop Voided
            if next(PLFeatures_Loops.Voided) then
                for userId, player in next, PLFeatures_Loops.Voided do
                    if player and player.Character and player.Character:FindFirstChild("Humanoid") and
                       player.Character:FindFirstChild("Head") then
                        if not (player.Character.Humanoid.Health == 0 or 
                                player.Character.Humanoid.Sit or 
                                player.TeamColor.Name == "Medium stone grey") then
                            if player.Character.Head.Position.Y < 699 then
                                local tempos = LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame
                                PL_BringPL(player, CFrame.new(0, 9e9, 0), true, true)
                                wait(0.5)
                                
                                if LocalPlayer.TeamColor == BrickColor.new("Bright blue") then
                                    workspace.Remote.TeamEvent:FireServer("Bright blue")
                                else
                                    workspace.Remote.TeamEvent:FireServer("Bright orange")
                                end
                                
                                LocalPlayer.CharacterAdded:Wait()
                                wait(0.5)
                                PL_LocTP(tempos)
                            end
                        end
                    end
                end
            end
            
            -- Loop CarFling
            if next(PLFeatures_Loops.CarFling) then
                for userId, player in next, PLFeatures_Loops.CarFling do
                    if player and player.Character and player.Character:FindFirstChild("Humanoid") and
                       player.Character:FindFirstChild("Head") then
                        if not (player.TeamColor == BrickColor.new("Medium stone grey") or 
                                player.Character.Humanoid.Health == 0 or 
                                player.Character.Humanoid.Sit) then
                            if player.Character.Head.Position.Y < 999 then
                                PL_CarFlingPL(player)
                                wait(2) -- Cooldown between flings
                            end
                        end
                    end
                end
            end
        end)
    end
end)

-- ============================================================================
-- TECHNIQUE 1: Platform Bring
-- Same skeleton as PL_BringPL. After sitting in the car, raycasts downward
-- from the target to detect the exact surface they're standing on, then
-- offsets the car seat BELOW that surface so they step/fall into it.
-- The bring loop then tracks their position with the same velocity prediction
-- used by the original, but applies an extra downward Y offset so the seat
-- is flush under their feet rather than on top of them.
-- ============================================================================
local function PL_PlatformBring(BringFrom)
    local success, err = pcall(function()
        -- ── Validate (identical to PL_BringPL) ──────────────────────────────
        if not BringFrom or not BringFrom.Character then PL_Notif("Error","Invalid player") return end
        if BringFrom.TeamColor == BrickColor.new("Medium stone grey") then PL_Notif("Error","Cannot bring neutral team") return end
        local targetHumanoid = BringFrom.Character:FindFirstChildOfClass("Humanoid")
        if not targetHumanoid or targetHumanoid.Health == 0 then PL_Notif("Error","Player is dead") return end
        if not (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")) then PL_Notif("Error","Your character not ready") return end
        if LocalPlayer.Character:FindFirstChild("Humanoid").Sit then PL_LAction("unsit", true) end
        local LastPos = LocalPlayer.Character.HumanoidRootPart.CFrame

        -- ── Raycast: detect the part the target is standing on ───────────────
        local VChar  = BringFrom.Character
        local VRoot0 = VChar:FindFirstChild("HumanoidRootPart")
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {VChar}
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        local hit = workspace:Raycast(VRoot0.Position, Vector3.new(0, -5, 0), rayParams)
        local floorY = hit and hit.Position.Y or (VRoot0.Position.Y - 3)

        -- ── Get car (identical to PL_BringPL) ───────────────────────────────
        local Car = nil
        local CarButton = workspace.Prison_ITEMS.buttons["Car Spawner"]["Car Spawner"]
        local ButtonPivot = CarButton:GetPivot()
        repeat
            task.wait()
            for _, v in pairs(workspace.CarContainer:GetChildren()) do
                if v:IsA("Model") and v:FindFirstChild("Body") and v.Body:FindFirstChild("VehicleSeat") and
                   v.Name ~= "DONOTUSECAR" and not v.Body.VehicleSeat.Occupant then
                    for __, vv in pairs(v.Body:GetChildren()) do
                        if vv:IsA("Seat") and not vv.Occupant then Car = v; break end
                    end
                    if Car then break end
                end
            end
            if not Car then
                coroutine.wrap(function()
                    PL_LocTP(ButtonPivot)
                    workspace.Remote.ItemHandler:InvokeServer(CarButton)
                end)()
            end
        until Car
        repeat task.wait() until Car:FindFirstChild("RWD") and Car:FindFirstChild("Body") and Car.Body:FindFirstChild("VehicleSeat")
        PLFeatures_States.IsBringing = true

        -- ── Sit in car (identical to PL_BringPL) ────────────────────────────
        local seattimeout = tick() + 8
        local LHuman = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local LRoot  = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        repeat
            task.wait()
            LHuman = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            LRoot  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if LHuman and LRoot then
                LRoot.CFrame = CFrame.new(Car.Body.VehicleSeat.Position)
                Car.Body.VehicleSeat:Sit(LHuman)
            end
        until (LHuman and LHuman.Sit) or tick() - seattimeout >= 0
        if not LHuman or not LHuman.Sit then
            PL_LAction("unsit", true); PLFeatures_States.IsBringing = false
            PL_LocTP(LastPos); Car.Name = "DONOTUSECAR"
            PL_Notif("Error","Failed to sit in car"); return
        end

        -- ── Find passenger seat (identical to PL_BringPL) ───────────────────
        if BringFrom.TeamColor == BrickColor.new("Medium stone grey") then
            PL_LAction("unsit",true); PLFeatures_States.IsBringing = false
            PL_LocTP(LastPos); PL_Notif("Error","Player joined neutral team"); return
        end
        local TargetSeat = nil
        for _, v in pairs(Car.Body:GetChildren()) do
            if v:IsA("Seat") and not v.Occupant then TargetSeat = v; break end
        end
        if not TargetSeat then
            PL_LocTP(LastPos); PLFeatures_States.IsBringing = false
            PL_Notif("Error","Car seats full"); return
        end

        -- ── Validate target (identical to PL_BringPL) ───────────────────────
        local VHuman = VChar:FindFirstChildOfClass("Humanoid")
        local VRoot  = VChar:FindFirstChild("HumanoidRootPart")
        if not (VChar and VHuman and VRoot) then
            PL_LAction("unsit",true); PL_LocTP(LastPos)
            PLFeatures_States.IsBringing = false; PL_Notif("Error","Target character invalid"); return
        end

        local Timeout = tick() + 17
        local CarSpin, SpinRad = false, 0
        task.spawn(function()
            Car.PrimaryPart = TargetSeat
            Car:SetPrimaryPartCFrame(VRoot.CFrame * CFrame.new(0, -0.3, 0))
            task.wait(4); CarSpin = true
        end)

        -- ── Bring loop — PLATFORM VARIANT ────────────────────────────────────
        -- Identical exit conditions to PL_BringPL.
        -- Difference: we push the seat DOWN to floorY so it sits BELOW their
        -- feet instead of on top of them, forcing a seat from underneath.
        repeat
            task.wait()
            local step1 = PL_CPing() / 2 / 2 / 2
            if TargetSeat.Occupant and not VHuman.Sit then
                for _, v in pairs(Car.Body:GetChildren()) do
                    if v:IsA("Seat") and not v.Occupant then TargetSeat = v; break end
                end
            end
            Car.PrimaryPart = TargetSeat
            local Movement = Vector3.new(VRoot.Velocity.X, 0, VRoot.Velocity.Z)
            local Predict  = (VRoot.CFrame - (Vector3.new(0, 0, -0.1) * step1)) + (Movement * (step1 * 28))
            -- Clamp Y to just below the detected floor surface
            local targetY  = floorY - 0.5
            local pos      = Predict.Position
            local belowCF  = CFrame.new(pos.X, targetY, pos.Z)
            if CarSpin then
                SpinRad = SpinRad + 30
                Car:SetPrimaryPartCFrame(belowCF * CFrame.Angles(0, math.rad(SpinRad), 0))
            else
                Car:SetPrimaryPartCFrame(belowCF)
            end
            if BringFrom.TeamColor == BrickColor.new("Medium stone grey") then break end
        until not LocalPlayer.Character or not LHuman or not LHuman.Sit or
              not BringFrom.Character or VChar ~= BringFrom.Character or
              VHuman.Sit or VHuman.Health == 0 or tick() - Timeout >= 0

        if VHuman and not VHuman.Sit then
            PL_LAction("unsit",true); PL_LocTP(LastPos)
            PLFeatures_States.IsBringing = false; PL_Notif("Error","Failed to bring player"); return
        end

        -- ── Deliver (identical to PL_BringPL) ───────────────────────────────
        -- Move car (with seated target) to your original position
        Car.PrimaryPart = Car:FindFirstChild("RWD")
        Car:SetPrimaryPartCFrame(LastPos)
        task.wait(0.1)
        PL_LAction("unsit", true)
        PL_LocTP(LastPos)
        PLFeatures_States.IsBringing = false
        PL_Notif("Success", "Brought " .. BringFrom.Name)
    end)
    if not success then
        PLFeatures_States.IsBringing = false
        warn("[PL_PlatformBring Error]", err)
        PL_Notif("Error","Platform Bring failed: " .. tostring(err))
    end
end


-- ============================================================================
-- TECHNIQUE 2: Walk-Intercept Bring
-- Identical skeleton to PL_BringPL. Unique behaviour in the bring loop:
-- lead multiplier boosted from 28x to 80x so the seat is placed AHEAD of
-- the walking player, letting them walk into it rather than chasing behind.
-- ============================================================================
local function PL_WalkInterceptBring(BringFrom)
    local success, err = pcall(function()
        if not BringFrom or not BringFrom.Character then PL_Notif("Error","Invalid player") return end
