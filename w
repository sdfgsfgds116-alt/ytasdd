    local lastFlipTime = 0

    function startAntiFlip()
        if antiFlipConn then antiFlipConn:Disconnect(); antiFlipConn=nil end
        antiFlipConn = RunService.Heartbeat:Connect(function()
            if not antiFlipEnabled then return end
            pcall(function()
                local char = LocalPlayer.Character
                if not char then return end
                local hum = char:FindFirstChild("Humanoid")
                if not hum or not hum.SeatPart then return end
                local seat = hum.SeatPart
                if not seat:IsA("VehicleSeat") then return end
                local vehicle = seat.Parent
                if not vehicle then return end
                local main = vehicle.PrimaryPart or vehicle:FindFirstChild("RWD") or vehicle:FindFirstChildWhichIsA("BasePart")
                if not main then return end
                if main.CFrame.UpVector.Y < -0.5 then
                    local now = tick()
                    if now - lastFlipTime < 1.0 then return end
                    lastFlipTime = now
                    local pos = main.Position
                    local _,yRot,_ = main.CFrame:ToEulerAnglesXYZ()
                    vehicle.PrimaryPart = main
                    vehicle:SetPrimaryPartCFrame(CFrame.new(pos)*CFrame.Angles(0,yRot,0))
                    for _,p in pairs(vehicle:GetDescendants()) do
                        if p:IsA("BasePart") then
                            p.AssemblyLinearVelocity  = Vector3.zero
                            p.AssemblyAngularVelocity = Vector3.zero
                        end
                    end
                end
