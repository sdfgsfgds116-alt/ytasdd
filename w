            d.isDead = false; d.lastRespawn = tick(); d.lastPos = nil; d.lastTime = tick(); return
        end
        if d.isDead or (tick()-d.lastDeath < ExDB.cfg.deathGrace)
                    or (tick()-d.lastRespawn < ExDB.cfg.respawnGrace)
                    or exInVehicle(p) then return end
        local now = tick()
        if d.lastPos then
            local dist = (hrp.Position - d.lastPos).Magnitude
            local dt   = now - d.lastTime
            if dt > 0.05 then
                -- Teleport check
                if dt < ExDB.cfg.teleportTimeWindow and dist > ExDB.cfg.teleportDistance then
                    d.tpCount += 1
                    table.insert(d.violations, { type="Teleport",
                        detail = string.format("%.0f studs in %.2fs", dist, dt),
                        time = os.date("%H:%M:%S") })
                end
                -- Speed check
                local speed = dist / dt
                if speed > ExDB.cfg.speedThreshold then
                    d.speedVio += 1
                    table.insert(d.violations, { type="Speed",
                        detail = string.format("%.0f st/s", speed),
                        time = os.date("%H:%M:%S") })
                end
            end
        end
        d.lastPos = hrp.Position; d.lastTime = now
        if (d.tpCount >= ExDB.cfg.minDetections or d.speedVio >= ExDB.cfg.minDetections)
                and not ExDB.detected[p.Name] then
            ExDB.detected[p.Name] = {
                player = p, tpCount = d.tpCount, speedVio = d.speedVio,
                violations = d.violations, firstSeen = os.date("%H:%M:%S"),
                total = d.tpCount + d.speedVio
            }
            Window:Notify({ Title = "C & C — Exploit Detected",
                Desc = p.Name .. " flagged (TP:" .. d.tpCount .. " SPD:" .. d.speedVio .. ")", Time = 5 })
        end
    end)
end

