CT.StartCarSurf = function()
    if CT.surfConn then CT.surfConn:Disconnect(); CT.surfConn = nil end
    CT.surfEnabled = true
    local myChar = LocalPlayer.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then CT.Notif("Car Surf", "Character not ready"); CT.surfEnabled = false; return end
    local bestVehicle = CT.FindNearestVehicle(true)
    if not bestVehicle then CT.Notif("Car Surf", "No vehicle nearby"); CT.surfEnabled = false; return end
    local root = CT.GetVehicleRoot(bestVehicle)
    if not root then CT.Notif("Car Surf", "Vehicle has no root part"); CT.surfEnabled = false; return end
    CT.Notif("Car Surf", "Surfing! Toggle off to dismount")
    CT.surfConn = RunService.Heartbeat:Connect(function()
        if not CT.surfEnabled then return end
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or not root.Parent then CT.surfEnabled = false; return end
        local surfOffset = CFrame.new(0, root.Size.Y / 2 + CT.surfHeight, 0)
        pcall(function() hrp.CFrame = root.CFrame * surfOffset end)
    end)
end

CT.StopCarSurf = function()
    CT.surfEnabled = false
    if CT.surfConn then CT.surfConn:Disconnect(); CT.surfConn = nil end
end

