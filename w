			ListSF.AutomaticCanvasSize = Enum.AutomaticSize.Y
			ListSF.CanvasSize = UDim2.new(0, 0, 0, 0)
			addToTheme('Function.Slider.Slider Bar Value', ListSF)

			local ListLL = Instance.new("UIListLayout", ListSF)
			ListLL.SortOrder = Enum.SortOrder.LayoutOrder
			ListLL.Padding = UDim.new(0, 3)
			local ListPad = Instance.new("UIPadding", ListSF)
			ListPad.PaddingTop = UDim.new(0, 2)

			local ITEM_H = 20
			local itemList = {}

			local function updateListSize()
				task.defer(function()
					local shown = math.min(#itemList, MaxShow)
					ListSF.Size = UDim2.new(1, 0, 0, shown * (ITEM_H + 3) + 4)
					CountLbl.Text = tostring(#itemList)
					local totalH = OuterLL.AbsoluteContentSize.Y + 18
					RealBg.Size = UDim2.new(1, 0, 0, totalH)
					Bg.Size = UDim2.new(1, 0, 0, totalH)
				end)
			end

			local function addItem(text)
				table.insert(itemList, text)
				local ItemF = Instance.new("Frame", ListSF)
				ItemF.Name = tostring(#itemList)
				ItemF.BackgroundColor3 = Color3.fromRGB(22, 20, 32)
				ItemF.BorderSizePixel = 0
				ItemF.Size = UDim2.new(1, -4, 0, ITEM_H)
				ItemF.LayoutOrder = #itemList
				addToTheme('Function.Dropdown.Dropdown Select.Background', ItemF)
				Instance.new("UICorner", ItemF).CornerRadius = UDim.new(0, 4)
				local ItemLbl = Instance.new("TextLabel", ItemF)
				ItemLbl.Size = UDim2.new(1, -8, 1, 0)
				ItemLbl.Position = UDim2.new(0, 6, 0, 0)
				ItemLbl.BackgroundTransparency = 1
				ItemLbl.BorderSizePixel = 0
				ItemLbl.Font = Enum.Font.Gotham
				ItemLbl.Text = tostring(text)
				ItemLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
				ItemLbl.TextTransparency = 0.25
				ItemLbl.TextSize = 10
				ItemLbl.TextXAlignment = Enum.TextXAlignment.Left
				ItemLbl.TextTruncate = Enum.TextTruncate.AtEnd
				addToTheme('Text & Icon', ItemLbl)
				if OnClick then
					local IClick = click(ItemF)
					IClick.MouseButton1Click:Connect(function()
						jc(IClick, ItemF)
						pcall(OnClick, text)
					end)
				end
				-- Animate in
				ItemF.BackgroundTransparency = 1
				tw({v = ItemF, t = 0.12, s = Enum.EasingStyle.Exponential, d = "Out", g = {BackgroundTransparency = 0}}):Play()
				updateListSize()
			end

			local New = {}
			function New:Add(text)
				addItem(text)
			end
			function New:Remove(text)
				for _, c in pairs(ListSF:GetChildren()) do
					if c:IsA("Frame") and c:FindFirstChild("TextLabel") and c.TextLabel.Text == tostring(text) then
						tw({v = c, t = 0.12, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 1}}):Play()
						delay(0.13, function() c:Destroy() end)
						for i, v in ipairs(itemList) do
							if v == text then table.remove(itemList, i); break end
						end
						break
					end
				end
				updateListSize()
			end
			function New:Clear()
				for _, c in pairs(ListSF:GetChildren()) do
					if c:IsA("Frame") then c:Destroy() end
				end
				itemList = {}
				updateListSize()
			end
			function New:SetItems(tbl)
				New:Clear()
				for _, v in ipairs(tbl) do addItem(v) end
			end
			function New:SetTitle(t) TitleLbl.Text = t end
			function New:SetVisible(t) RealBg.Visible = t end

			-- Initial items
			for _, v in ipairs(Items) do addItem(v) end

			return New
		end

