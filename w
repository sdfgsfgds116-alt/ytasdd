				warning = { bg = Color3.fromRGB(55, 45, 5),    accent = Color3.fromRGB(240, 185, 30),  icon = "⚠" },
				error   = { bg = Color3.fromRGB(65, 10, 15),   accent = Color3.fromRGB(235, 60, 75),   icon = "✕" },
