local function ai_post(url, headers, body)
    local opts = { Url = url, Method = "POST", Headers = headers, Body = body }
    local fns = {}
    pcall(function() if syn       and syn.request   then fns[#fns+1] = syn.request    end end)
    pcall(function() if request                     then fns[#fns+1] = request        end end)
    pcall(function() if http_request                then fns[#fns+1] = http_request   end end)
    pcall(function() if fluxus and fluxus.request   then fns[#fns+1] = fluxus.request end end)
    for _, fn in ipairs(fns) do
        local ok, res = pcall(fn, opts)
        if ok and res then return res end
    end
    return nil
end

