				if on then
					if _pulseConn then return end
					local RS = game:GetService("RunService")
					local t0 = tick()
					_pulseConn = RS.Heartbeat:Connect(function()
						local alpha = (math.sin((tick() - t0) * 3) + 1) / 2
						Fill.BackgroundTransparency = 0.3 * alpha
					end)
				else
					if _pulseConn then _pulseConn:Disconnect(); _pulseConn = nil end
					Fill.BackgroundTransparency = 0
				end
			end
			return New
		end

