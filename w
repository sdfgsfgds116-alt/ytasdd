    local seat, vehicle = CT.GetSeat()
    if not seat then CT.Notif("Orbit Car", "Must be seated in a vehicle"); return end
    local root = CT.GetVehicleRoot(vehicle)
    if not root then CT.Notif("Orbit Car", "No vehicle root"); return end
    if CT.orbitConn then CT.orbitConn:Disconnect(); CT.orbitConn = nil end
    CT.orbitEnabled = true
    CT.orbitAngle   = 0
    local myChar = LocalPlayer.Character
    local hum    = myChar and myChar:FindFirstChildOfClass("Humanoid")
    if hum then hum:ChangeState(Enum.HumanoidStateType.Running) end
    CT.Notif("Orbit Car", "Orbiting " .. SelectedActionTarget.Name)
    CT.orbitConn = RunService.Heartbeat:Connect(function(dt)
        if not CT.orbitEnabled then return end
        local target = SelectedActionTarget
        if not (target and target.Character) then CT.orbitEnabled = false; return end
        local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if not tHRP or not root.Parent then CT.orbitEnabled = false; return end
        CT.orbitAngle = (CT.orbitAngle + dt * CT.orbitSpeed) % 360
        local rad = math.rad(CT.orbitAngle)
        local offset = Vector3.new(
            math.cos(rad) * CT.orbitRadius,
            CT.orbitHeight,
            math.sin(rad) * CT.orbitRadius
        )
        local targetCF = CFrame.new(tHRP.Position + offset)
            * CFrame.Angles(0, rad + math.pi / 2, 0)
        pcall(function()
            vehicle.PrimaryPart = root
            vehicle:SetPrimaryPartCFrame(targetCF)
            for _, p in ipairs(vehicle:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.AssemblyLinearVelocity  = Vector3.zero
                    p.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end)
    end)
