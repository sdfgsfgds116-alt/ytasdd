					-- Flash yellow to indicate update
					tw({v = lbl, t = 0.1, s = Enum.EasingStyle.Linear, d = "Out", g = {TextColor3 = Color3.fromRGB(255, 220, 80)}}):Play()
					delay(0.3, function()
						tw({v = lbl, t = 0.2, s = Enum.EasingStyle.Linear, d = "Out", g = {TextColor3 = Color3.fromRGB(255, 255, 255)}}):Play()
					end)
				end
			end
			function New:Refresh(tbl)
				for k, v in pairs(tbl) do
					New:SetStat(k, v)
				end
			end
			function New:SetTitle(t) TitleLbl.Text = t end
			function New:SetVisible(t) RealBg.Visible = t end
			return New
		end

