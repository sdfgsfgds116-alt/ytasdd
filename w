-- ============================================================================
-- BULLET EVASION
-- ============================================================================
do
    local _BE_enabled = false

    -- ── Config ────────────────────────────────────────────────────────────────
    local _BE_Config = {
        AimAngleDeg   = 35,   -- aim-angle filter (degrees)
        ThreatRadius  = 10,   -- perp miss-distance (studs)
        DodgeSpeed    = 60,   -- lateral speed during dodge (studs/s)
        DodgeDuration = 0.22, -- seconds velocity is held after last threat
    }
    local _BE_COS_THRESHOLD = math.cos(math.rad(_BE_Config.AimAngleDeg))

    -- ── State ─────────────────────────────────────────────────────────────────
    local _BE_Players    = game:GetService("Players")
    local _BE_RunService = game:GetService("RunService")
    local _BE_LocalPlayer = _BE_Players.LocalPlayer

    local _BE_Character:  Model   = nil
    local _BE_HRP:        BasePart = nil
    local _BE_Humanoid:   Humanoid = nil

    local _BE_activeLV:     LinearVelocity? = nil
    local _BE_expireThread: thread?         = nil
    local _BE_dodgeXZ = Vector3.zero

    local _BE_heartbeatConn = nil
    local _BE_remoteConn    = nil
    local _BE_charConn      = nil

    -- ── Heartbeat: preserve gravity while dodge is active ─────────────────────
    local function _BE_startHeartbeat()
        if _BE_heartbeatConn then return end
        _BE_heartbeatConn = _BE_RunService.Heartbeat:Connect(function()
            if not _BE_enabled then return end
            if _BE_activeLV and _BE_activeLV.Parent and _BE_HRP then
                local realY = _BE_HRP.AssemblyLinearVelocity.Y
                _BE_activeLV.VectorVelocity = Vector3.new(_BE_dodgeXZ.X, realY, _BE_dodgeXZ.Z)
            end
        end)
    end

    local function _BE_stopHeartbeat()
        if _BE_heartbeatConn then
            _BE_heartbeatConn:Disconnect()
            _BE_heartbeatConn = nil
        end
    end

    -- ── LinearVelocity constraint ──────────────────────────────────────────────
    local function _BE_getOrCreateLV()
        if _BE_activeLV and _BE_activeLV.Parent then return _BE_activeLV end
        if not _BE_HRP then return nil end
        local attach = _BE_HRP:FindFirstChildOfClass("Attachment") :: Attachment
        if not attach then
            attach = Instance.new("Attachment")
            attach.Parent = _BE_HRP
        end
        local lv = Instance.new("LinearVelocity")
        lv.Attachment0            = attach
        lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        lv.RelativeTo             = Enum.ActuatorRelativeTo.World
        lv.MaxForce               = 5e5
        lv.VectorVelocity         = Vector3.zero
        lv.Parent                 = _BE_HRP
        _BE_activeLV = lv
        return lv
    end

    local function _BE_cleanupLV()
        _BE_dodgeXZ = Vector3.zero
        if _BE_activeLV then _BE_activeLV:Destroy(); _BE_activeLV = nil end
        if _BE_expireThread then task.cancel(_BE_expireThread); _BE_expireThread = nil end
    end

    -- ── Dodge trigger ─────────────────────────────────────────────────────────
    local function _BE_startDodge(dir: Vector3)
        if not _BE_enabled then return end
        if not _BE_HRP or not _BE_Humanoid or _BE_Humanoid.Health <= 0 then return end
        _BE_dodgeXZ = dir * _BE_Config.DodgeSpeed
        _BE_getOrCreateLV()
        if _BE_expireThread then task.cancel(_BE_expireThread) end
        _BE_expireThread = task.delay(_BE_Config.DodgeDuration, function()
            _BE_dodgeXZ = Vector3.zero
            if _BE_activeLV then _BE_activeLV:Destroy(); _BE_activeLV = nil end
            _BE_expireThread = nil
        end)
    end

    -- ── Shot evaluation ───────────────────────────────────────────────────────
    local function _BE_evaluateShot(shotStart, shotEnd, playerPos)
        local rayVec = shotEnd - shotStart
        local rayLen = rayVec.Magnitude
        if rayLen < 0.001 then return nil end
        local rayUnit = rayVec / rayLen

        local toPlayer     = playerPos - shotStart
        local toPlayerDist = toPlayer.Magnitude
        if toPlayerDist < 0.001 then return nil end
        if rayUnit:Dot(toPlayer / toPlayerDist) < _BE_COS_THRESHOLD then return nil end

        local t    = math.clamp(toPlayer:Dot(rayUnit), 0, rayLen)
        local perp = (shotStart + rayUnit * t - playerPos).Magnitude
        if perp >= _BE_Config.ThreatRadius then return nil end

        local lateral = toPlayer - rayUnit * toPlayer:Dot(rayUnit)
        if lateral.Magnitude < 0.3 then
            local up = math.abs(rayUnit:Dot(Vector3.yAxis)) < 0.9
                and Vector3.yAxis or Vector3.xAxis
            lateral = rayUnit:Cross(up)
        end
        local flat = Vector3.new(lateral.X, 0, lateral.Z)
        if flat.Magnitude < 0.01 then
            local a = math.random() * math.pi * 2
            flat = Vector3.new(math.cos(a), 0, math.sin(a))
        end

        local missWeight = 1 + (_BE_Config.ThreatRadius - perp) / _BE_Config.ThreatRadius
        return flat.Unit * missWeight
    end

    -- ── Shot handler ──────────────────────────────────────────────────────────
    local function _BE_onShotFired(shots)
        if not _BE_enabled then return end
        if not _BE_Character or not _BE_HRP or not _BE_Humanoid then return end
        if _BE_Humanoid.Health <= 0 then return end

        local playerPos   = _BE_HRP.Position
        local accumulated = Vector3.zero
        local count       = 0

        for _, shotData in ipairs(shots) do
            local startPos = shotData[1]
            local endPos   = shotData[2]
            if typeof(startPos) ~= "Vector3" or typeof(endPos) ~= "Vector3" then continue end
            if (startPos - playerPos).Magnitude < 6 then continue end
            local weighted = _BE_evaluateShot(startPos, endPos, playerPos)
            if weighted then
                accumulated += weighted
                count += 1
            end
        end

        if count == 0 then return end
        local blended = accumulated.Unit
        if blended.Magnitude < 0.01 then return end
        _BE_startDodge(blended)
    end

    -- ── Character wiring ──────────────────────────────────────────────────────
    local function _BE_wireCharacter(char)
        _BE_cleanupLV()
        _BE_Character = char
        _BE_HRP       = char:WaitForChild("HumanoidRootPart", 10) :: BasePart
        _BE_Humanoid  = char:WaitForChild("Humanoid", 10)         :: Humanoid
    end

    -- ── Enable / Disable ──────────────────────────────────────────────────────
    local function _BE_enable()
        if _BE_LocalPlayer.Character then
            _BE_wireCharacter(_BE_LocalPlayer.Character)
        end
        _BE_charConn = _BE_LocalPlayer.CharacterAdded:Connect(_BE_wireCharacter)
        _BE_startHeartbeat()

        local GunRemotes     = game:GetService("ReplicatedStorage"):FindFirstChild("GunRemotes")
        local ReplicateEvent = GunRemotes and GunRemotes:FindFirstChild("ReplicateEvent")
        if ReplicateEvent then
            _BE_remoteConn = ReplicateEvent.OnClientEvent:Connect(_BE_onShotFired)
        else
            -- Async wait so we don't block the toggle callback
            task.spawn(function()
                local rs = game:GetService("ReplicatedStorage")
                local gr = rs:WaitForChild("GunRemotes", 30)
                if not gr then return end
                local re = gr:WaitForChild("ReplicateEvent", 30)
                if not re or not _BE_enabled then return end
                _BE_remoteConn = re.OnClientEvent:Connect(_BE_onShotFired)
            end)
        end
    end

    local function _BE_disable()
        _BE_cleanupLV()
        _BE_stopHeartbeat()
        if _BE_remoteConn then _BE_remoteConn:Disconnect(); _BE_remoteConn = nil end
        if _BE_charConn   then _BE_charConn:Disconnect();   _BE_charConn   = nil end
        _BE_Character = nil; _BE_HRP = nil; _BE_Humanoid = nil
    end

    -- ── UI Toggle ─────────────────────────────────────────────────────────────
    UtilityTab:Toggle({
        Title = "Bullet Evasion",
        Desc  = "Listens to GunRemotes.ReplicateEvent and automatically sidesteps bullets aimed at you using a LinearVelocity constraint. Gravity and jumping are unaffected.",
        Value = false,
        Callback = function(v)
            _BE_enabled = v
            if v then
                task.spawn(function() pcall(_BE_enable) end)
            else
                task.spawn(function() pcall(_BE_disable) end)
            end
        end,
    })
end
