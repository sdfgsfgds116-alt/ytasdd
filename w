			local function updateSize()
				task.defer(function()
					local gridH = GridLayout.AbsoluteContentSize.Y
					local total = InnerLL.AbsoluteContentSize.Y + 18
					RealBg.Size = UDim2.new(1, 0, 0, total)
					Bg.Size = UDim2.new(1, 0, 0, total)
				end)
			end
			delay(0.1, updateSize)
			InnerLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateSize)
			GridLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateSize)

			local New = {}
			function New:SetStat(key, val)
				local lbl = cellMap[tostring(key)]
