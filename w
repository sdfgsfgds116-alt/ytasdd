		--        section:Toggle(p)  / section:Slider(p)  / etc (same as Tab methods)
		-- ═══════════════════════════════════════════════════════════════════
		function Func:Collapsible(p)
			local Title   = p.Title   or 'Section'
			local OpenDef = p.Open    ~= false
			local Accent  = p.Color   or nil

			-- Header bar
			local HeaderRealBg = Instance.new("Frame", ScrollingFrame_1)
