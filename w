do
    local _TRN_enabled             = false
    local _TRN_skidActive          = false
    local _TRN_teleportDown        = true
    local _TRN_lastTeleport        = 0
    local _TRN_cameraCompensation  = 0
    local _TRN_TELEPORT_INTERVAL   = 0.01
    local _TRN_TELEPORT_OFFSET     = 80
    local _TRN_groundY             = nil  -- absolute ground Y captured at activation; oscillation snaps to this or this-80

    local _TRN_stash               = {}
    local _TRN_plugs               = {}
    local _TRN_heartbeat           = nil
    local _TRN_renderStep          = nil
    local _TRN_charConn            = nil
    local _TRN_playerAddedConn     = nil
    local _TRN_playerRemovingConn  = nil

    local _TRN_Players    = game:GetService("Players")
    local _TRN_RunService = game:GetService("RunService")
    local _TRN_nih        = _TRN_Players.LocalPlayer

    local function _TRN_grabRoot(char)
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function _TRN_saveOriginal(plr, root)
        if _TRN_stash[plr] then return end
        _TRN_stash[plr] = {
            size         = root.Size,
            transparency = root.Transparency,
            shape        = root.Shape,
            material     = root.Material,
        }
    end

    local function _TRN_smack(plr)
        if plr == _TRN_nih then return end
        local char = plr.Character
        local root = _TRN_grabRoot(char)
        if not root then return end
        _TRN_saveOriginal(plr, root)
        root.CanCollide   = false
        root.Size         = Vector3.new(15, 15, 15)
        root.Transparency = 0.5
        root.Material     = Enum.Material.ForceField
        root.Shape        = Enum.PartType.Block
    end

    local function _TRN_unsmack(plr)
        local data = _TRN_stash[plr]
        if not data then return end
        local char = plr.Character
        local root = _TRN_grabRoot(char)
        if root then
            root.Size         = data.size
            root.Transparency = data.transparency
            root.Shape        = data.shape
            root.Material     = data.material
        end
        _TRN_stash[plr] = nil
    end

    local function _TRN_hideMyHRP()
        local char = _TRN_nih.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Transparency = 1
            hrp.LocalTransparencyModifier = 1
        end
    end

    local function _TRN_hookPlr(plr)
        if _TRN_plugs[plr] then return end
        _TRN_plugs[plr] = {}
        _TRN_plugs[plr].spawn = plr.CharacterAdded:Connect(function()
            task.wait(0.15)
            _TRN_smack(plr)
        end)
        if plr.Character then
            task.wait(0.15)
            _TRN_smack(plr)
        end
    end

    local function _TRN_unhookPlr(plr)
        _TRN_unsmack(plr)
        if _TRN_plugs[plr] then
            for _, conn in pairs(_TRN_plugs[plr]) do conn:Disconnect() end
            _TRN_plugs[plr] = nil
        end
    end

    local function _TRN_onCharacterSpawned(char)
        _TRN_skidActive          = false
        _TRN_cameraCompensation  = 0
        _TRN_teleportDown        = true

        local hum = char:WaitForChild("Humanoid", 5)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)

        if not (hum and hrp) then return end

        -- Immediately kill the oscillation the moment this character dies,
        -- so the corpse is never bounced 80 studs above the ground.
        hum.Died:Connect(function()
            _TRN_skidActive         = false
            _TRN_cameraCompensation = 0
        end)

        -- Wait until the character lands before activating
        repeat task.wait()
        until hrp.AssemblyLinearVelocity.Magnitude < 1
            or hum.FloorMaterial ~= Enum.Material.Air
            or hum.Health <= 0        -- bail out if killed mid-wait
        task.wait(0.1)

        -- Only activate if the character is still alive
        if hum.Health <= 0 then return end

        _TRN_hideMyHRP()
        _TRN_groundY      = hrp.Position.Y  -- snapshot the spawn-floor Y; heartbeat will snap to this or this-80
        _TRN_teleportDown = true             -- first move is always downward (underground)
        _TRN_skidActive   = true
    end

    local function _TRN_enable()
        _TRN_skidActive         = false
        _TRN_cameraCompensation = 0
        _TRN_teleportDown       = true
        _TRN_stash              = {}
        _TRN_plugs              = {}

        -- Expand hitboxes for all current players
        for _, plr in ipairs(_TRN_Players:GetPlayers()) do
            _TRN_hookPlr(plr)
        end
        _TRN_playerAddedConn    = _TRN_Players.PlayerAdded:Connect(_TRN_hookPlr)
        _TRN_playerRemovingConn = _TRN_Players.PlayerRemoving:Connect(_TRN_unhookPlr)

        -- Handle own character spawns
        _TRN_charConn = _TRN_nih.CharacterAdded:Connect(function(char)
            -- Immediately halt any in-progress oscillation so the heartbeat cannot
            -- fire a stray +80 upward teleport on the freshly-spawned character
            -- before task.spawn gets a chance to run _TRN_onCharacterSpawned.
            _TRN_skidActive         = false
            _TRN_cameraCompensation = 0
            _TRN_teleportDown       = true
            _TRN_groundY            = nil  -- clear stale ground Y; will be re-captured after landing
            task.spawn(_TRN_onCharacterSpawned, char)
        end)
        if _TRN_nih.Character then
            task.spawn(_TRN_onCharacterSpawned, _TRN_nih.Character)
        end

        -- RenderStepped: cancel the visual camera bounce caused by the Y oscillation
        _TRN_renderStep = _TRN_RunService.RenderStepped:Connect(function()
            if _TRN_skidActive and _TRN_cameraCompensation ~= 0 then
                local cam = workspace.CurrentCamera
                cam.CFrame = cam.CFrame + Vector3.new(0, _TRN_cameraCompensation, 0)
            end
        end)

        -- Heartbeat: enforce hitboxes every frame + drive the rapid Y teleport
        _TRN_heartbeat = _TRN_RunService.Heartbeat:Connect(function()
            if not _TRN_enabled then return end
            local now = tick()
            for _, plr in ipairs(_TRN_Players:GetPlayers()) do
                if plr ~= _TRN_nih then
                    _TRN_smack(plr)
                end
            end
            _TRN_hideMyHRP()
            if _TRN_skidActive and (now - _TRN_lastTeleport) >= _TRN_TELEPORT_INTERVAL then
                local char = _TRN_nih.Character
                local hrp  = _TRN_grabRoot(char)
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                -- Never oscillate a dead or dying character
                if hrp and hum and hum.Health > 0 and _TRN_groundY then
                    -- Absolute Y snap: always move to exactly groundY (surface) or
                    -- groundY-OFFSET (underground). Using a delta to preserve CFrame
                    -- rotation while forcing the Y to the correct absolute level.
                    -- This prevents any drift or above-ground teleport regardless of
                    -- what state teleportDown was left in on a previous character.
                    local targetY = _TRN_teleportDown
                        and (_TRN_groundY - _TRN_TELEPORT_OFFSET)   -- underground
                        or   _TRN_groundY                            -- back to surface
                    hrp.CFrame = hrp.CFrame + Vector3.new(0, targetY - hrp.Position.Y, 0)
                    _TRN_cameraCompensation = _TRN_teleportDown and _TRN_TELEPORT_OFFSET or 0
                    _TRN_teleportDown = not _TRN_teleportDown
                    _TRN_lastTeleport = now
                elseif hum and hum.Health <= 0 then
                    -- Character is dead — halt the oscillation immediately
                    _TRN_skidActive         = false
                    _TRN_cameraCompensation = 0
                end
            end
        end)
    end

    local function _TRN_disable()
        _TRN_skidActive         = false
        _TRN_cameraCompensation = 0
        if _TRN_heartbeat          then _TRN_heartbeat:Disconnect();          _TRN_heartbeat = nil          end
        if _TRN_renderStep         then _TRN_renderStep:Disconnect();         _TRN_renderStep = nil         end
        if _TRN_charConn           then _TRN_charConn:Disconnect();           _TRN_charConn = nil           end
        if _TRN_playerAddedConn    then _TRN_playerAddedConn:Disconnect();    _TRN_playerAddedConn = nil    end
        if _TRN_playerRemovingConn then _TRN_playerRemovingConn:Disconnect(); _TRN_playerRemovingConn = nil end
        for _, plr in ipairs(_TRN_Players:GetPlayers()) do
            _TRN_unhookPlr(plr)
        end
        _TRN_stash = {}
        _TRN_plugs = {}
        -- Restore own HRP visibility
        local char = _TRN_nih.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.Transparency = 1
                hrp.LocalTransparencyModifier = 1
            end
        end
    end

    UtilityTab:Toggle({
        Title = "Transmission",
        Desc  = "Rapidly oscillates your Y position while expanding all player hitboxes — lets you wallbang through floors with full camera compensation.",
        Value = false,
        Callback = function(v)
            _TRN_enabled = v
            if v then
                task.spawn(function() pcall(_TRN_enable) end)
            else
                task.spawn(function() pcall(_TRN_disable) end)
            end
        end,
    })
end
