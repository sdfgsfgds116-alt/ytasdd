							tw({v = b.Label, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out",
								g = {TextTransparency = sel and 0 or 0.5}}):Play()
						end
						pcall(Callback, Value)
					end)
				end
			end

			renderOptions()

			-- Auto-resize RealBg
			local function updateRGSize()
				task.defer(function()
					RealBg.Size = UDim2.new(1, 0, 0, math.max(35, Bg.AbsoluteSize.Y))
				end)
			end
			delay(0.1, updateRGSize)

			local New = {}
			function New:SetValue(v)
				Value = v
				for o, b in pairs(optionButtons) do
					local sel = (o == Value)
					b.Frame.BackgroundColor3 = sel and Color3.fromRGB(91, 68, 209) or Color3.fromRGB(44, 42, 62)
					b.Label.TextTransparency = sel and 0 or 0.5
				end
				pcall(Callback, Value)
			end
			function New:SetOptions(opts)
				Options = opts
				renderOptions()
			end
			function New:SetTitle(t) TitleLbl.Text = t end
			function New:SetDesc(t) end
			function New:SetVisible(t) RealBg.Visible = t end
			return New
		end

