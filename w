			DispLbl.Text = Fmt(Mode == 'down' and Duration or 0)
			addToTheme('Text & Icon', DispLbl)

			-- Start/Stop button
			local StartBtnF = Instance.new("Frame", RF)
			StartBtnF.BackgroundColor3 = Color3.fromRGB(50, 160, 80)
			StartBtnF.BorderSizePixel = 0
			StartBtnF.Size = UDim2.new(0, 36, 0, 22)
			StartBtnF.LayoutOrder = 2
			Instance.new("UICorner", StartBtnF).CornerRadius = UDim.new(0, 6)
			local StartBtnLbl = Instance.new("TextLabel", StartBtnF)
			StartBtnLbl.Size = UDim2.new(1, 0, 1, 0)
			StartBtnLbl.BackgroundTransparency = 1
			StartBtnLbl.BorderSizePixel = 0
			StartBtnLbl.Font = Enum.Font.GothamBold
			StartBtnLbl.Text = "▶"
			StartBtnLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
			StartBtnLbl.TextSize = 11
			local StartClick = click(StartBtnF)

			local elapsed = 0
			local running = false
			local _conn = nil
			local RS = game:GetService("RunService")

			local function _render()
				local display = Mode == 'down' and math.max(Duration - elapsed, 0) or elapsed
				DispLbl.Text = Fmt(display)
			end

			local function _stop()
				running = false
				if _conn then _conn:Disconnect(); _conn = nil end
				StartBtnLbl.Text = "▶"
				StartBtnF.BackgroundColor3 = Color3.fromRGB(50, 160, 80)
			end

			local function _start()
				if running then _stop(); return end
				running = true
				StartBtnLbl.Text = "■"
				StartBtnF.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
				local last = tick()
				_conn = RS.Heartbeat:Connect(function()
					local now = tick()
					elapsed = elapsed + (now - last)
					last = now
					_render()
					if Mode == 'down' and elapsed >= Duration then
						_stop()
						pcall(OnFinish)
					end
				end)
			end

			StartClick.MouseButton1Click:Connect(function()
				if running then _stop() else _start() end
			end)

			-- Reset button
			local ResetBtnF = Instance.new("Frame", RF)
			ResetBtnF.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
			ResetBtnF.BorderSizePixel = 0
			ResetBtnF.Size = UDim2.new(0, 30, 0, 22)
			ResetBtnF.LayoutOrder = 3
			Instance.new("UICorner", ResetBtnF).CornerRadius = UDim.new(0, 6)
			local ResetBtnLbl = Instance.new("TextLabel", ResetBtnF)
			ResetBtnLbl.Size = UDim2.new(1, 0, 1, 0)
			ResetBtnLbl.BackgroundTransparency = 1
			ResetBtnLbl.BorderSizePixel = 0
			ResetBtnLbl.Font = Enum.Font.GothamBold
			ResetBtnLbl.Text = "↺"
			ResetBtnLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
			ResetBtnLbl.TextSize = 12
			local ResetClick = click(ResetBtnF)
			ResetClick.MouseButton1Click:Connect(function()
				_stop()
				elapsed = 0
				_render()
			end)

			_render()

			local New = {}
			function New:Start() if not running then _start() end end
			function New:Stop() _stop() end
			function New:Reset() _stop(); elapsed = 0; _render() end
			function New:SetTitle(t) Config:SetTitle(t) end
			function New:SetVisible(t) TimerBg.Parent.Visible = t end
			return New
		end

