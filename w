    -- ── Part Manipulation (Magnet + Launch + Vortex) ──────────────────────────
    -- Network setup
    local function PM_SetupNetwork()
        pcall(function() settings().Physics.AllowSleep = false end)
        pcall(function() settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalPhysicsThrottle.Disabled end)
        if not getgenv().NetworkBypass then
            getgenv().NetworkBypass = true
            pcall(function()
                if hookmetamethod then
                    local old
                    old = hookmetamethod(game, "__index", newcclosure and newcclosure(function(self, idx)
                        if idx == "NetworkOwnershipRule" then return Enum.NetworkOwnership.Manual end
                        return old(self, idx)
                    end) or function(self, idx)
                        if idx == "NetworkOwnershipRule" then return Enum.NetworkOwnership.Manual end
                        return old(self, idx)
                    end)
                elseif getrawmetatable and setreadonly then
                    local mt = getrawmetatable(game)
                    if mt and mt.__index then
                        local old = mt.__index
                        local ok = pcall(setreadonly, mt, false)
                        if ok then
                            mt.__index = newcclosure and newcclosure(function(self, idx)
                                if idx == "NetworkOwnershipRule" then return Enum.NetworkOwnership.Manual end
                                return old(self, idx)
                            end) or function(self, idx)
                                if idx == "NetworkOwnershipRule" then return Enum.NetworkOwnership.Manual end
                                return old(self, idx)
                            end
                            pcall(setreadonly, mt, true)
                        end
                    end
                end
            end)
        end
    end
    PM_SetupNetwork()

    -- Part Magnet system
    magnetEnabled  = false
    magnetConnection = nil
    local PM_magnetParts = {}
    local PM_effectModel = Instance.new("Model", workspace)
    PM_effectModel.Name = "MagnetEffects"

    magnetConfig = { MaxRadius = 50, Strength = 100, Direction = "Pull", MaxParts = 500 }

    function canManipulatePart(part)
        if not part or not part:IsA("BasePart") then return false end
        if part.Anchored then return false end
        if part:IsDescendantOf(LocalPlayer.Character) then return false end
        return true
    end

    function claimPart(part)
        pcall(function() part:SetNetworkOwner(LocalPlayer) end)
    end

    function releasePart(part)
        pcall(function() part:SetNetworkOwnershipAuto() end)
    end

    local function PM_calculateMagnetForce(part, rootPosition, direction)
        local distance = (part.Position - rootPosition).Magnitude
        if distance == 0 then return Vector3.zero end
        local strength = magnetConfig.Strength * (1 - math.min(distance / magnetConfig.MaxRadius, 1))
        return direction.Unit * strength * part:GetMass()
    end

    local function PM_updateMagnet()
        if not magnetEnabled then return end
        local character = LocalPlayer.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        local rootPosition = rootPart.Position
        local parts = workspace:FindPartsInRegion3(
            Region3.new(
                rootPosition - Vector3.new(magnetConfig.MaxRadius, magnetConfig.MaxRadius, magnetConfig.MaxRadius),
                rootPosition + Vector3.new(magnetConfig.MaxRadius, magnetConfig.MaxRadius, magnetConfig.MaxRadius)
            ),
            nil,
            magnetConfig.MaxParts
        )
        for _, part in ipairs(parts) do
            local direction = (magnetConfig.Direction == "Pull") and (rootPosition - part.Position) or (part.Position - rootPosition)
            if canManipulatePart(part) then
                claimPart(part)
                local force = PM_calculateMagnetForce(part, rootPosition, direction)
                part:ApplyImpulse(force * 0.03)
                if not PM_magnetParts[part] then
                    PM_magnetParts[part] = true
                    part.AncestryChanged:Connect(function()
                        PM_magnetParts[part] = nil
                        releasePart(part)
                    end)
                end
            elseif PM_magnetParts[part] then
                PM_magnetParts[part] = nil
                releasePart(part)
            end
        end
    end

    function cleanupMagnet()
        for part, _ in pairs(PM_magnetParts) do
            if part and part.Parent then releasePart(part) end
        end
        PM_magnetParts = {}
        if magnetConnection then magnetConnection:Disconnect(); magnetConnection = nil end
        PM_effectModel:ClearAllChildren()
    end

    -- Launch system
    launchStrength = 100
    launchHeight   = 50

    -- Part Vortex system
    vortexEnabled   = false
    vortexRadius    = 90
    vortexStrength  = 3
    vortexDirection = 1
    local PM_vortexParts = {}
    vortexConnection = nil

    local function PM_updateVortex()
        if not vortexEnabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            return
        end
        local rootPos = LocalPlayer.Character.HumanoidRootPart.Position
        -- Iterate pre-built candidate list, not workspace:GetDescendants()
        for part in pairs(PM_vortexParts._candidates or {}) do
            if part and part.Parent then
                local distance = (part.Position - rootPos).Magnitude
                if distance <= vortexRadius then
                    if not PM_vortexParts[part] then
                        PM_vortexParts[part] = {
                            Velocity = Instance.new("BodyVelocity", part),
                            OriginalProps = {
                                CanCollide = part.CanCollide,
                                CustomPhysicalProperties = part.CustomPhysicalProperties
                            }
                        }
                        PM_vortexParts[part].Velocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                        part.CanCollide = false
                        part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                    end
                    local toPart  = part.Position - rootPos
                    local tangent = Vector3.new(-toPart.Z, 0, toPart.X) * vortexDirection
                    tangent = tangent.Unit
                    local inward = -toPart.Unit * 0.3
                    local force = (1 - (distance / vortexRadius)) * vortexStrength * 100
                    PM_vortexParts[part].Velocity.Velocity = (tangent + inward) * force
                elseif PM_vortexParts[part] then
                    part.CanCollide = PM_vortexParts[part].OriginalProps.CanCollide
                    part.CustomPhysicalProperties = PM_vortexParts[part].OriginalProps.CustomPhysicalProperties
                    PM_vortexParts[part].Velocity:Destroy()
                    PM_vortexParts[part] = nil
                end
            end
        end
    end

    function startVortex()
        if vortexConnection then vortexConnection:Disconnect() end
        if PM_vortexParts._descConn then PM_vortexParts._descConn:Disconnect() end
        if PM_vortexParts._descRemConn then PM_vortexParts._descRemConn:Disconnect() end
        vortexEnabled = true

        -- Build candidate set of all eligible parts once
        PM_vortexParts._candidates = {}
        local char = LocalPlayer.Character
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part.Anchored
                and (not char or not part:IsDescendantOf(char))
            then
                PM_vortexParts._candidates[part] = true
            end
        end

        -- Keep candidate set up to date reactively
        PM_vortexParts._descConn = workspace.DescendantAdded:Connect(function(part)
            if not vortexEnabled then return end
            if not part:IsA("BasePart") or part.Anchored then return end
            local c = LocalPlayer.Character
            if c and part:IsDescendantOf(c) then return end
            PM_vortexParts._candidates[part] = true
        end)
        PM_vortexParts._descRemConn = workspace.DescendantRemoving:Connect(function(part)
            PM_vortexParts._candidates[part] = nil
        end)

        vortexConnection = RunService.Heartbeat:Connect(PM_updateVortex)
    end

    function stopVortex()
        vortexEnabled = false
        if PM_vortexParts._descConn then PM_vortexParts._descConn:Disconnect(); PM_vortexParts._descConn = nil end
        if PM_vortexParts._descRemConn then PM_vortexParts._descRemConn:Disconnect(); PM_vortexParts._descRemConn = nil end
        PM_vortexParts._candidates = nil
        for part, data in pairs(PM_vortexParts) do
            if type(part) ~= "string" and part and part.Parent then
                part.CanCollide = data.OriginalProps.CanCollide
                part.CustomPhysicalProperties = data.OriginalProps.CustomPhysicalProperties
                data.Velocity:Destroy()
            end
        end
        PM_vortexParts = {}
        if vortexConnection then vortexConnection:Disconnect(); vortexConnection = nil end
    end

    -- Export magnet/vortex update functions for UI toggle callbacks
    getgenv().PM_updateMagnet = PM_updateMagnet
    getgenv().PM_updateVortex = PM_updateVortex
    getgenv().PM_vortexParts  = PM_vortexParts

    -- ── Part Ring / Orbit ──────────────────────────────────────────────────────
    -- Fixed version of PartsFE ring logic.
    -- Key bug fixes vs. original:
    --   1. Parts are ONLY claimed/modified when the feature is enabled (no global
    --      DescendantAdded hook that runs at startup).
    --   2. Original CanCollide + CustomPhysicalProperties are stored per-part and
    --      fully restored (including Velocity = zero) when disabled.
    --   3. No persistent global Network.Velocity heartbeat that forces movement on
    --      parts even when the ring is toggled off.
    --   4. Network ownership is released (SetNetworkOwnershipAuto) on stop.

    ringOrbitEnabled    = false
    ringOrbitConnection = nil
    local RO            = { parts = {}, angle = 0, pf_frozen = {}, ps_parts = {} }  -- consolidated to stay under 200-local limit

    ringOrbitConfig = {
        radius             = 50,
        height             = 10,
        rotationSpeed      = 10,
        attractionStrength = 300,
        targetMode         = "self",   -- "self" | "player" | "part"
        targetPlayerName   = "",
        targetPart         = nil,
    }

    local function RO_getCenter()
        if ringOrbitConfig.targetMode == "player" and ringOrbitConfig.targetPlayerName ~= "" then
            local name = ringOrbitConfig.targetPlayerName:lower()
            for _, p in pairs(Players:GetPlayers()) do
                if p.Name:lower():find(name, 1, true) or p.DisplayName:lower():find(name, 1, true) then
                    if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        return p.Character.HumanoidRootPart.Position
                    end
                end
            end
        elseif ringOrbitConfig.targetMode == "part" then
            if ringOrbitConfig.targetPart and ringOrbitConfig.targetPart.Parent then
                return ringOrbitConfig.targetPart.Position
            end
        end
        -- Fallback: self
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            return char.HumanoidRootPart.Position
        end
        return nil
    end

    local function RO_update()
        if not ringOrbitEnabled then return end
        local center = RO_getCenter()
        if not center then return end

        -- Build active list and prune removed parts (no workspace scan here)
        local list = {}
        for part, _ in pairs(RO.parts) do
            if part and part.Parent then
                list[#list + 1] = part
            else
                RO.parts[part] = nil
            end
        end

        local count = #list
        if count == 0 then return end

        RO.angle = (RO.angle + math.rad(ringOrbitConfig.rotationSpeed)) % (2 * math.pi)

        for i, part in ipairs(list) do
            local angle  = RO.angle + (2 * math.pi * (i - 1) / count)
            local target = Vector3.new(
                center.X + math.cos(angle) * ringOrbitConfig.radius,
                center.Y + ringOrbitConfig.height,
                center.Z + math.sin(angle) * ringOrbitConfig.radius
            )
            local delta = target - part.Position
            local mag   = delta.Magnitude
            if mag > 0.01 then
                local speed = math.clamp(mag * ringOrbitConfig.attractionStrength * 0.05, 0, 2000)
                part.AssemblyLinearVelocity = delta.Unit * speed
            end
        end
    end

    function startRingOrbit()
        RO.angle = 0
        if ringOrbitConnection then ringOrbitConnection:Disconnect() end
        if RO.roDescConn then RO.roDescConn:Disconnect() end
        ringOrbitEnabled = true

        -- Claim existing parts once
        local char = LocalPlayer.Character
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part.Anchored
                and (not char or not part:IsDescendantOf(char))
                and not RO.parts[part]
            then
                claimPart(part)
                RO.parts[part] = { cc = part.CanCollide, cpp = part.CustomPhysicalProperties }
                part.CanCollide = false
                part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
            end
        end

        -- Reactively claim parts added while active (no per-frame scan needed)
        RO.roDescConn = workspace.DescendantAdded:Connect(function(part)
            if not ringOrbitEnabled then return end
            if not part:IsA("BasePart") or part.Anchored then return end
            local c = LocalPlayer.Character
            if c and part:IsDescendantOf(c) then return end
            if RO.parts[part] then return end
            claimPart(part)
            RO.parts[part] = { cc = part.CanCollide, cpp = part.CustomPhysicalProperties }
            part.CanCollide = false
            part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
        end)

        ringOrbitConnection = RunService.Heartbeat:Connect(RO_update)
    end

    function stopRingOrbit()
        ringOrbitEnabled = false
        if ringOrbitConnection then ringOrbitConnection:Disconnect(); ringOrbitConnection = nil end
        if RO.roDescConn then RO.roDescConn:Disconnect(); RO.roDescConn = nil end
        for part, data in pairs(RO.parts) do
            if part and part.Parent then
                part.CanCollide               = data.cc
                part.CustomPhysicalProperties = data.cpp
                part.AssemblyLinearVelocity   = Vector3.zero
                releasePart(part)
            end
        end
        RO.parts = {}
    end

    -- ── Part Freeze ────────────────────────────────────────────────────────────
    -- Anchors all nearby unanchored parts in place; fully restores them on stop.

    partFreezeEnabled = false
    partFreezeRadius  = 80
    function startPartFreeze()
        partFreezeEnabled = true
        RO.pf_frozen = {}
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local center = root.Position
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part.Anchored
                and not part:IsDescendantOf(LocalPlayer.Character)
                and (part.Position - center).Magnitude <= partFreezeRadius
            then
                pcall(function() part:SetNetworkOwner(LocalPlayer) end)
                RO.pf_frozen[part] = true
                part.Anchored   = true
            end
        end
        local n = 0; for _ in pairs(RO.pf_frozen) do n = n + 1 end
        Window:Notify({ Title="Part Freeze", Desc=("Froze %d parts"):format(n), Time=3 })
    end

    function stopPartFreeze()
        partFreezeEnabled = false
        for part, _ in pairs(RO.pf_frozen) do
            if part and part.Parent then
                part.Anchored = false
                pcall(function() part:SetNetworkOwnershipAuto() end)
            end
        end
        RO.pf_frozen = {}
        Window:Notify({ Title="Part Freeze", Desc="Parts unfrozen", Time=2 })
    end

    -- ── Part Shield ────────────────────────────────────────────────────────────
    -- Arranges all nearby unanchored parts in a sphere formation around the
    -- player using golden-angle distribution for even coverage.

    partShieldEnabled    = false
    partShieldConnection = nil
    partShieldRadius     = 8
    partShieldStrength   = 500
    RO.ps_update = function()
        if not partShieldEnabled then return end
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local center = root.Position

        -- Build active list (no workspace scan here)
        local list = {}
        for part, _ in pairs(RO.ps_parts) do
            if part and part.Parent then list[#list + 1] = part
            else RO.ps_parts[part] = nil end
        end

        local count = #list
        if count == 0 then return end

        for i, part in ipairs(list) do
            -- Golden-angle spherical distribution
            local phi   = math.acos(1 - 2 * (i / count))
            local theta = math.pi * (1 + math.sqrt(5)) * i
            local target = Vector3.new(
                center.X + partShieldRadius * math.sin(phi) * math.cos(theta),
                center.Y + partShieldRadius * math.cos(phi),
                center.Z + partShieldRadius * math.sin(phi) * math.sin(theta)
            )
            local delta = target - part.Position
            local mag   = delta.Magnitude
            if mag > 0.01 then
                local speed = math.clamp(mag * partShieldStrength * 0.1, 0, 2000)
                part.AssemblyLinearVelocity = delta.Unit * speed
            end
        end
    end

    function startPartShield()
        if partShieldConnection then partShieldConnection:Disconnect() end
        if RO.psDescConn then RO.psDescConn:Disconnect() end
        partShieldEnabled = true

        -- Claim existing parts once
        local char = LocalPlayer.Character
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part.Anchored
                and (not char or not part:IsDescendantOf(char))
                and not RO.ps_parts[part]
            then
                claimPart(part)
                RO.ps_parts[part] = { cc = part.CanCollide, cpp = part.CustomPhysicalProperties }
                part.CanCollide = false
                part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
            end
        end

        -- Reactively claim parts added while active
        RO.psDescConn = workspace.DescendantAdded:Connect(function(part)
            if not partShieldEnabled then return end
            if not part:IsA("BasePart") or part.Anchored then return end
            local c = LocalPlayer.Character
            if c and part:IsDescendantOf(c) then return end
            if RO.ps_parts[part] then return end
            claimPart(part)
            RO.ps_parts[part] = { cc = part.CanCollide, cpp = part.CustomPhysicalProperties }
            part.CanCollide = false
            part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
        end)

        partShieldConnection = RunService.Heartbeat:Connect(RO.ps_update)
    end

    function stopPartShield()
        partShieldEnabled = false
        if partShieldConnection then partShieldConnection:Disconnect(); partShieldConnection = nil end
        if RO.psDescConn then RO.psDescConn:Disconnect(); RO.psDescConn = nil end
        for part, data in pairs(RO.ps_parts) do
            if part and part.Parent then
                part.CanCollide               = data.cc
                part.CustomPhysicalProperties = data.cpp
                part.AssemblyLinearVelocity   = Vector3.zero
                releasePart(part)
            end
        end
        RO.ps_parts = {}
    end

    getgenv().RO_update = RO_update

    -- ── Carwalk ───────────────────────────────────────────────────────────────
    RO.cw_bringing = false

    RO.cw_findCar = function()
        if not workspace:FindFirstChild("CarContainer") then return nil end
        for _,v in pairs(workspace.CarContainer:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("Body") and v.Body:FindFirstChild("VehicleSeat") and not v.Body.VehicleSeat.Occupant then
                for _,vv in pairs(v.Body:GetChildren()) do
                    if vv:IsA("Seat") and not vv.Occupant then return v end
                end
            end
        end
        return nil
    end

    function CarWalk_Run()
        if RO.cw_bringing then Window:Notify({Title="Carwalk",Desc="Already running!",Time=3}); return end
        local char  = LocalPlayer.Character
        local human = char and char:FindFirstChildOfClass("Humanoid")
        local root  = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not human or not root then Window:Notify({Title="Carwalk",Desc="No character found.",Time=3}); return end
        local Car = RO.cw_findCar()
        if not Car then Window:Notify({Title="Carwalk",Desc="No available car found.",Time=4}); return end
        local waitTimeout = tick()
        repeat
            task.wait()
            if tick()-waitTimeout > 10 then Window:Notify({Title="Carwalk",Desc="Car parts failed to load.",Time=3}); return end
        until Car:FindFirstChild("RWD") and Car:FindFirstChild("Body") and Car.Body:FindFirstChild("VehicleSeat")
        RO.cw_bringing = true
        local LastPos = root.CFrame
        human:SetStateEnabled(Enum.HumanoidStateType.Seated,false)
        local sitDone=false; local sitTimeout=tick()
        while not sitDone do
            task.wait()
            pcall(function()
                root.CFrame = CFrame.new(Car.Body.VehicleSeat.Position)
                Car.Body.VehicleSeat:Sit(human)
                sitDone = human.Sit or (tick()-sitTimeout > 6)
            end)
        end
        if not human.Sit then
            Window:Notify({Title="Carwalk",Desc="Failed to sit in car.",Time=3})
            human:SetStateEnabled(Enum.HumanoidStateType.Seated,true)
            RO.cw_bringing=false; return
        end
        Car.PrimaryPart = Car:WaitForChild("RWD")
        Car:SetPrimaryPartCFrame(LastPos)
        RO.cw_bringing = false
        Window:Notify({Title="Carwalk",Desc="Walking with a car!",Time=4})
    end

end -- vehicle backend scope


-- Wave Dreams spiral logo embedded as base64 – written to executor workspace on load
local function _b64dec(s)
    local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    s = s:gsub('[^'..b..'=]','')
    return (s:gsub('.', function(c)
        if c == '=' then return '' end
        local r, f = '', b:find(c) - 1
        for i = 6, 1, -1 do r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
        return r
    end):gsub('%d%d%d%d%d%d%d%d', function(x)
        local n = 0
        for i = 1, 8 do n = n + (x:sub(i,i)=='1' and 2^(8-i) or 0) end
        return string.char(n)
    end))
end

