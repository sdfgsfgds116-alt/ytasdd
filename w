-- CLICK CAR FLING (NAA SkidFling logic)
-- ============================================================================
do
    local _CFlingEnabled   = false
    local _CFlingActive    = false   -- prevents overlapping flings
    local _CFlingConn      = nil
    local _CFlingManager   = { cFlingOldPos = nil }
    local _CFlingTool      = nil
    local _CFlingToolConn  = nil

    function clickCarFling_removeTool()
        if _CFlingToolConn then _CFlingToolConn:Disconnect(); _CFlingToolConn = nil end
        if _CFlingTool then pcall(function()
            if _CFlingTool.Parent then _CFlingTool:Destroy() end
        end) end
        _CFlingTool = nil
    end

    function clickCarFling_giveTool()
        clickCarFling_removeTool()

        local tool = Instance.new("Tool")
        tool.Name = "Click Car Fling"
        tool.RequiresHandle = false
        tool.ToolTip = "Equip and click an unanchored vehicle to fling it (NAA logic)"
        tool.CanBeDropped = false

        _CFlingToolConn = tool.Activated:Connect(function()
            local CFPlayers = game:GetService("Players")
            local Mouse = CFPlayers.LocalPlayer:GetMouse()
            local Target = Mouse.Target
            if not Target or not Target:IsA("BasePart") then return end
            if Target.Anchored then return end
            -- Skip player characters
            if CFPlayers:GetPlayerFromCharacter(Target.Parent) then return end
            if Target.Parent and CFPlayers:GetPlayerFromCharacter(Target.Parent.Parent) then return end

            task.spawn(function()
                pcall(_DoCarFling, Target)
            end)
        end)

        _CFlingTool = tool
        local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
        if bp then tool.Parent = bp end
    end

    local function _CFlingGetHumanoid(char)
        return char and char:FindFirstChildWhichIsA("Humanoid")
    end

    local function _DoCarFling(CarPart)
        if _CFlingActive then return end
        _CFlingActive = true

        local CFPlayers   = game:GetService("Players")
        local CFPlayer    = CFPlayers.LocalPlayer
        local Character   = CFPlayer.Character
        local Humanoid    = _CFlingGetHumanoid(Character)
        local RootPart    = Humanoid and Humanoid.RootPart

        if not Character or not Humanoid or not RootPart then
            _CFlingActive = false
            return
        end

        if not _CFlingManager.cFlingOldPos or RootPart.Velocity.Magnitude < 50 then
            _CFlingManager.cFlingOldPos = RootPart.CFrame
        end

        local OrgDestroyHeight = workspace.FallenPartsDestroyHeight
        workspace.FallenPartsDestroyHeight = 0/0

        local BV = Instance.new("BodyVelocity")
        BV.Parent    = RootPart
        BV.Velocity  = Vector3.new(9e8, 9e8, 9e8)
        BV.MaxForce  = Vector3.new(1/0, 1/0, 1/0)

        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

        local function FPos(BasePart, Pos, Ang)
            RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
            Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
            RootPart.Velocity    = Vector3.new(9e7, 9e7 * 10, 9e7)
            RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
        end

        local function ResolveVehicleBasePart(hitPart)
            if not hitPart then return nil end
            local model = hitPart:FindFirstAncestorOfClass("Model")
            if not model then return hitPart end

            if model.PrimaryPart and model.PrimaryPart:IsA("BasePart") and not model.PrimaryPart.Anchored then
                return model.PrimaryPart
            end

            local preferred = {
                "RWD", "Body", "Chassis", "Main", "Hood", "Base", "VehicleSeat"
            }
            for _, name in ipairs(preferred) do
                local p = model:FindFirstChild(name, true)
                if p and p:IsA("BasePart") and not p.Anchored then
                    return p
                end
            end

            local best, bestMass = nil, -1
            for _, d in ipairs(model:GetDescendants()) do
                if d:IsA("BasePart") and not d.Anchored then
                    local m = d:GetMass()
                    if m > bestMass then
                        best = d
                        bestMass = m
                    end
                end
            end
            return best or hitPart
        end

        local function LockToVehicleBottom(BasePart, lockSeconds)
            local t0 = tick()
            while BasePart and BasePart.Parent and Humanoid.Health > 0 and tick() - t0 < lockSeconds do
                local bottomOffset = (BasePart.Size.Y * 0.5) + (RootPart.Size.Y * 0.5) + 0.12
                local attachCF = BasePart.CFrame * CFrame.new(0, -bottomOffset, 0)
                RootPart.CFrame = attachCF
                Character:SetPrimaryPartCFrame(attachCF)
                RootPart.Velocity = BasePart.Velocity
                RootPart.RotVelocity = BasePart.RotVelocity
                task.wait()
            end
        end

        local function SFBasePart(BasePart)
            local RunService = game:GetService("RunService")
            local TimeToWait = 4
            local Time       = tick()
            local contactHits = 0
            local touchOffsets = {
                Vector3.new(0, 0, 0),
                Vector3.new(0.45, 0, 0),
                Vector3.new(-0.45, 0, 0),
                Vector3.new(0, 0, 0.45),
                Vector3.new(0, 0, -0.45),
            }
            local idx = 1

            while RootPart and BasePart and BasePart.Parent and Humanoid.Health > 0 and tick() <= Time + TimeToWait do
                local bottomOffset = (BasePart.Size.Y * 0.5) + (RootPart.Size.Y * 0.5) + 0.08
                local sideOffset = touchOffsets[idx]
                idx = (idx % #touchOffsets) + 1

                -- Hard-stick below the car and follow it exactly while touchfling pushes.
                local attachCF = BasePart.CFrame * CFrame.new(sideOffset.X, -bottomOffset, sideOffset.Z)
                RootPart.CFrame = attachCF
                Character:SetPrimaryPartCFrame(attachCF)

                -- Keep relative position stable so we "lay" under the car while it moves.
                RootPart.Velocity = BasePart.Velocity
                RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)

                -- Extra touch pressure from all body parts while staying attached.
                for _, p in ipairs(Character:GetChildren()) do
                    if p:IsA("BasePart") then
                        p.Velocity = BasePart.Velocity + Vector3.new(0, -2, 0)
                        p.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
                    end
                end

                if BasePart.Velocity.Magnitude > 320 then
                    contactHits = contactHits + 1
                end
                if contactHits >= 6 then
                    break
                end

                RunService.Heartbeat:Wait()
            end
        end

        local targetPart = ResolveVehicleBasePart(CarPart)
        if not targetPart then
            BV:Destroy()
            Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
            workspace.FallenPartsDestroyHeight = OrgDestroyHeight
            _CFlingActive = false
            return
        end

        -- Initial lock helps keep contact on moving vehicles.
        LockToVehicleBottom(targetPart, 0.35)

        SFBasePart(targetPart)

        BV:Destroy()
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        workspace.CurrentCamera.CameraSubject = Humanoid

        repeat
            RootPart.CFrame = _CFlingManager.cFlingOldPos * CFrame.new(0, 0.5, 0)
            Character:SetPrimaryPartCFrame(_CFlingManager.cFlingOldPos * CFrame.new(0, 0.5, 0))
            Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            for _, x in next, Character:GetChildren() do
                if x:IsA("BasePart") then
                    x.Velocity    = Vector3.new()
                    x.RotVelocity = Vector3.new()
                end
            end
            task.wait()
        until (RootPart.Position - _CFlingManager.cFlingOldPos.p).Magnitude < 25

        workspace.FallenPartsDestroyHeight = OrgDestroyHeight
        _CFlingActive = false
    end

    UtilityTab:Toggle({
        Title = "Click Car Fling",
        Desc = "Click any unanchored car/vehicle to fling it using NAA fling logic.",
        Value = false,
        Callback = function(v)
            _CFlingEnabled = v
            if _CFlingConn then
                _CFlingConn:Disconnect()
                _CFlingConn = nil
            end
            if v then
                local CFPlayers = game:GetService("Players")
                local Mouse = CFPlayers.LocalPlayer:GetMouse()
                _CFlingConn = Mouse.Button1Down:Connect(function()
                    if not _CFlingEnabled or _CFlingActive then return end
                    local Target = Mouse.Target
                    if not Target or not Target:IsA("BasePart") then return end
                    if Target.Anchored then return end
                    -- Skip player characters
                    if CFPlayers:GetPlayerFromCharacter(Target.Parent) then return end
                    if Target.Parent and CFPlayers:GetPlayerFromCharacter(Target.Parent.Parent) then return end
                    task.spawn(function() pcall(_DoCarFling, Target) end)
                end)
            end
        end,
    })
end
