local _logoOptions      = { 'Spiral (Default)', 'Hammer & Sword', 'None' }
local _currentLogoChoice = 'Spiral (Default)'
local _logoColor        = Color3.fromRGB(220, 30, 30)  -- default: red (matches original logo)

local function _applyLogo(choice)
    if not _guiIcon then return end
    _guiIcon.BackgroundTransparency = 1
    if choice == 'Spiral (Default)' then
        _guiIcon.Image           = _spiralImage ~= '' and _spiralImage or 'rbxassetid://0'
        _guiIcon.ImageRectSize   = Vector2.new(0, 0)
        _guiIcon.ImageRectOffset = Vector2.new(0, 0)
        _guiIcon.Size            = UDim2.new(0, 30, 0, 30)
        _guiIcon.ImageColor3     = _logoColor
    elseif choice == 'Hammer & Sword' then
        _guiIcon.Image                  = _hammerSwordImage ~= '' and _hammerSwordImage or 'rbxassetid://0'
        _guiIcon.ImageRectSize          = Vector2.new(0, 0)
        _guiIcon.ImageRectOffset        = Vector2.new(0, 0)
        _guiIcon.BackgroundTransparency = 1
        -- Smaller & more compact than the default 30×30
        _guiIcon.Size                   = UDim2.new(0, 22, 0, 22)
        _guiIcon.ImageColor3            = _logoColor
    elseif choice == 'None' then
        _guiIcon.Image       = 'rbxassetid://0'
        _guiIcon.Size        = UDim2.new(0, 30, 0, 30)
        _guiIcon.ImageColor3 = _logoColor
    end
    _currentLogoChoice = choice
end

local function _applyLogoColor(col)
    _logoColor = col
    if _guiIcon then
        _guiIcon.ImageColor3 = col
    end
end

