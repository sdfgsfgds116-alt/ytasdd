-- ============================================================================
-- FFF (FULL FORCE FIELD) IMPLEMENTATION
-- ============================================================================
-- Mirrors AutoRespawn exactly: CharacterAdded owns both hrp/hum AND the
-- HealthChanged listener, so they share the same reference — just like
-- AutoRespawn's hum.Died closes over the same hrp from CharacterAdded.

do
    local FFF_TeamEvent       = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("RequestTeamChange")
    local FFF_HealthThreshold = 80    -- default; overwritten by UI slider at runtime

    local function FFF_FixCam()
        pcall(function()
            game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
            workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
            if LocalPlayer.Character then
                local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    workspace.CurrentCamera.CameraSubject = humanoid
                end
            end
        end)
    end

    local function FFF_TeleportAfterSwap(savedCFrame)
        -- Wait for the final character that exists after the full team swap
        local newChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local newHrp  = newChar:WaitForChild("HumanoidRootPart")
        task.wait(0.15)
        pcall(function() newHrp.CFrame = savedCFrame end)
        FFF_FixCam()
    end

    LocalPlayer.CharacterAdded:Connect(function(char)
        local hrp = char:WaitForChild("HumanoidRootPart")
        local hum = char:WaitForChild("Humanoid")

        -- firedThisLife resets automatically each CharacterAdded — one trigger per life
        local firedThisLife = false

        hum.HealthChanged:Connect(function(newHealth)
            if not AntiFeatures_Enabled.FFF then return end
            if firedThisLife then return end
            if newHealth > 0 and newHealth <= FFF_HealthThreshold then
                firedThisLife  = true
                local savedCFrame = hrp.CFrame   -- capture position right now

                if FFF_TeamEvent then
                    task.spawn(function()
                        local currentTeam = LocalPlayer.Team

                        if currentTeam == Env.Teams.Inmates then
                            repeat task.wait()
                                FFF_TeamEvent:InvokeServer(game:GetService("Teams"):FindFirstChild("Neutral"), 1)
                            until LocalPlayer.Team == game:GetService("Teams"):FindFirstChild("Neutral")

                            repeat task.wait()
                                FFF_TeamEvent:InvokeServer(Env.Teams.Inmates, 1)
                            until LocalPlayer.Team == Env.Teams.Inmates

                            -- Team swap done — NOW teleport to saved position
                            FFF_TeleportAfterSwap(savedCFrame)

                        elseif currentTeam == Env.Teams.Guards then
                            repeat task.wait()
                                FFF_TeamEvent:InvokeServer(game:GetService("Teams"):FindFirstChild("Neutral"), 1)
                            until LocalPlayer.Team == game:GetService("Teams"):FindFirstChild("Neutral")

                            repeat task.wait()
                                FFF_TeamEvent:InvokeServer(Env.Teams.Guards, 1)
                            until LocalPlayer.Team == Env.Teams.Guards

                            FFF_TeleportAfterSwap(savedCFrame)

                        elseif currentTeam == Env.Teams.Criminals then
                            repeat task.wait()
                                FFF_TeamEvent:InvokeServer(game:GetService("Teams"):FindFirstChild("Neutral"), 1)
                            until LocalPlayer.Team == game:GetService("Teams"):FindFirstChild("Neutral")

                            repeat task.wait()
                                FFF_TeamEvent:InvokeServer(Env.Teams.Inmates, 1)
                            until LocalPlayer.Team == Env.Teams.Inmates

                            FFF_TeleportAfterSwap(savedCFrame)
                        end
                    end)
                end
            end
        end)
    end)

    -- Expose threshold setter so the UI slider can update it at runtime
    _G.FFF_SetThreshold = function(v) FFF_HealthThreshold = v end
end

-- ============================================================================
-- ANTI-TOUCH IMPLEMENTATION
-- ============================================================================
-- Constant invisibility - hides you completely when enabled, no proximity checking

do
    local AT_Active = false
    local AT_Vanished = false
    local AT_VanishCFrame = nil
    -- store original LocalTransparencyModifier per part; this is client-only and safe
    local AT_OriginalLocalTrans = {}
    -- store original CanCollide (best-effort) so we can try to restore it
    local AT_OriginalCanCollide = {}
    
    local function gatherCharacterParts(char)
        local parts = {}
        if not char then return parts end
        for _,desc in ipairs(char:GetDescendants()) do
            if desc:IsA("BasePart") then
                table.insert(parts, desc)
            end
        end
        return parts
    end
    
    local function vanishLocal()
        if AT_Vanished then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        AT_Vanished = true
        -- store vanish position so we can return there (if character persists)
        AT_VanishCFrame = hrp.CFrame
        AT_OriginalLocalTrans = {}
        AT_OriginalCanCollide = {}
        
        -- Set local-only invisibility using LocalTransparencyModifier so we don't teleport or modify server-visible properties.
        for _, part in ipairs(gatherCharacterParts(char)) do
            pcall(function()
                -- record previous LocalTransparencyModifier
                AT_OriginalLocalTrans[part] = part.LocalTransparencyModifier or 0
                part.LocalTransparencyModifier = 1
                -- record and attempt to disable collisions locally (this may or may not replicate depending on ownership)
                AT_OriginalCanCollide[part] = part.CanCollide
                pcall(function() part.CanCollide = false end)
            end)
        end
        
        -- optionally stabilize character locally so they don't fall into other players while vanished
        pcall(function()
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.PlatformStand = true
            end
        end)
    end
    
    local function restoreLocal()
        if not AT_Vanished then return end
        local char = LocalPlayer.Character
        -- if character doesn't exist yet, wait until it spawns and restore then
        if not char or not char.Parent then
            local conn
            conn = LocalPlayer.CharacterAdded:Connect(function(c)
                task.wait(0.1)
                if conn then conn:Disconnect(); conn = nil end
                -- restore position if we have one saved
                local hrp = c:WaitForChild("HumanoidRootPart", 5)
                if hrp and AT_VanishCFrame then
                    pcall(function() hrp.CFrame = AT_VanishCFrame end)
                end
                -- restore LocalTransparencyModifier for new character parts won't apply (they're new objects),
                -- but we reset vanished flag so future vanish cycles are clean.
                AT_Vanished = false
                AT_OriginalLocalTrans = {}
                AT_OriginalCanCollide = {}
            end)
            return
        end
        
        -- move back to saved CFrame if still available
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and AT_VanishCFrame then
            pcall(function() hrp.CFrame = AT_VanishCFrame end)
        end
        
        -- restore LocalTransparencyModifier and CanCollide where possible
        for part, oldLocal in pairs(AT_OriginalLocalTrans) do
            if part and part.Parent then
                pcall(function()
                    part.LocalTransparencyModifier = oldLocal or 0
                end)
            end
        end
        for part, oldCan in pairs(AT_OriginalCanCollide) do
            if part and part.Parent then
                pcall(function()
                    part.CanCollide = oldCan ~= nil and oldCan or true
                end)
            end
        end
        
        -- restore humanoid state
        pcall(function()
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.PlatformStand = false end
        end)
        
        AT_Vanished = false
        AT_OriginalLocalTrans = {}
        AT_OriginalCanCollide = {}
    end
    
    -- Function to enable Anti Touch (constant vanish)
    function EnableAntiTouch()
        if AT_Active then return end
        AT_Active = true
        vanishLocal()
    end
    
    -- Function to disable Anti Touch (restore visibility)
    function DisableAntiTouch()
        if not AT_Active then return end
        AT_Active = false
        restoreLocal()
    end
    
    -- Clean up on respawn: if Anti Touch is active, re-vanish after respawn
    LocalPlayer.CharacterAdded:Connect(function(char)
        if AT_Active then
            task.wait(0.2)  -- wait a moment for character to load
            vanishLocal()
        end
    end)
    
    -- Clean up on character removing
    LocalPlayer.CharacterRemoving:Connect(function()
        -- keep vanished state; restore will try when a character exists again
    end)
end

-- ============================================================================
-- ANTI-TRIP IMPLEMENTATION
-- Prevents any script from forcing PlatformStand or Sit on the local player.
-- Uses a high-frequency Heartbeat loop + property-change listeners that are
-- rebuilt every respawn so they are always authoritative.
-- ============================================================================
do
    local AT_tripConn   = nil  -- Heartbeat polling connection
    local AT_psConn     = nil  -- PlatformStand property listener
    local AT_sitConn    = nil  -- Sit property listener
    local AT_stateConn  = nil  -- HumanoidStateType listener

    local function AntiTrip_BindCharacter(char)
        -- Disconnect stale listeners
        if AT_psConn    then AT_psConn:Disconnect();    AT_psConn    = nil end
        if AT_sitConn   then AT_sitConn:Disconnect();   AT_sitConn   = nil end
        if AT_stateConn then AT_stateConn:Disconnect(); AT_stateConn = nil end

        local hum = char:WaitForChild("Humanoid", 5)
        if not hum then return end

        -- Immediately enforce upright state
        local function enforce()
            if not AntiFeatures_Enabled.AntiTrip then return end
            if hum.PlatformStand then hum.PlatformStand = false end
            if hum.Sit           then hum.Sit           = false end
        end

        -- Property-change signals catch external scripts the instant they write
        AT_psConn  = hum:GetPropertyChangedSignal("PlatformStand"):Connect(enforce)
        AT_sitConn = hum:GetPropertyChangedSignal("Sit"):Connect(enforce)

        -- Also block FallingDown humanoid state (used by trip-kick tools)
        AT_stateConn = hum.StateChanged:Connect(function(_, new)
            if not AntiFeatures_Enabled.AntiTrip then return end
            if new == Enum.HumanoidStateType.FallingDown
            or new == Enum.HumanoidStateType.Seated then
                hum.PlatformStand = false
                hum.Sit           = false
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)
    end

    -- Heartbeat fallback: catches any residual frame where state slipped through
    AntiFeatures_Connections.AntiTrip = RunService.Heartbeat:Connect(function()
        if not AntiFeatures_Enabled.AntiTrip then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if hum.PlatformStand then hum.PlatformStand = false end
        if hum.Sit           then hum.Sit           = false end
    end)

    -- Re-bind whenever character respawns
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        AntiTrip_BindCharacter(char)
    end)

    -- Bind for the current character if already spawned
    if LocalPlayer.Character then
        AntiTrip_BindCharacter(LocalPlayer.Character)
    end
end

-- ============================================================================
-- ANTI-RAGDOLL IMPLEMENTATION
-- Blocks every known ragdoll vector:
--   1) HumanoidStateType.Ragdoll / FallingDown  → forced back to Running
--   2) Motor6D.MaxVelocity zeroing (common ragdoll technique)
--   3) BallSocketConstraints / HingeConstraints added to the character
--   4) PlatformStand gating (shared path with Anti-Trip, belt-and-suspenders)
-- All listeners are rebuilt on respawn.
-- ============================================================================
do
    local ARG_stateConn   = nil
    local ARG_psConn      = nil
    local ARG_descConn    = nil  -- ChildAdded watcher for injected constraints

    -- Motor6D names that legitimate ragdolls zero out
    local MOTOR_NAMES = {
        "Neck", "Left Shoulder", "Right Shoulder",
        "Left Hip", "Right Hip", "RootJoint"
    }

    local function ARG_restoreMotors(char)
        -- Walk every Motor6D and restore MaxVelocity if it was clamped to 0
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("Motor6D") and v.MaxVelocity == 0 then
                v.MaxVelocity = 0.1  -- Roblox default is 0.1
            end
        end
    end

    local function ARG_removeInjectedConstraints(char)
        -- Some ragdoll scripts inject BallSocketConstraints into the character;
        -- destroy any that weren't there at spawn (they have no Part0 ancestry
        -- match, or can be identified as foreign by their parent being a limb).
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") then
                -- Only destroy constraints that live inside the character
                -- (legitimate gear/tools never put these on the player body)
                local ok, _ = pcall(function() v:Destroy() end)
                if not ok then end  -- silently skip if protected
            end
        end
    end

    local function AntiRagdoll_BindCharacter(char)
        -- Disconnect stale listeners
        if ARG_stateConn then ARG_stateConn:Disconnect(); ARG_stateConn = nil end
        if ARG_psConn    then ARG_psConn:Disconnect();    ARG_psConn    = nil end
        if ARG_descConn  then ARG_descConn:Disconnect();  ARG_descConn  = nil end

        local hum = char:WaitForChild("Humanoid", 5)
        if not hum then return end

        -- Ensure AutoRotate is on (ragdolls often disable it)
        hum.AutoRotate = true

        -- Block ragdoll / fallingdown states
        ARG_stateConn = hum.StateChanged:Connect(function(_, new)
            if not AntiFeatures_Enabled.AntiRagdoll then return end
            if new == Enum.HumanoidStateType.Ragdoll
            or new == Enum.HumanoidStateType.FallingDown then
                hum.PlatformStand = false
                hum.AutoRotate    = true
                ARG_restoreMotors(char)
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end)

        -- PlatformStand is the root of most ragdoll implementations
        ARG_psConn = hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
            if not AntiFeatures_Enabled.AntiRagdoll then return end
            if hum.PlatformStand then
                hum.PlatformStand = false
                hum.AutoRotate    = true
                ARG_restoreMotors(char)
            end
        end)

        -- Watch for injected constraints being added to the character tree
        ARG_descConn = char.DescendantAdded:Connect(function(obj)
            if not AntiFeatures_Enabled.AntiRagdoll then return end
            if obj:IsA("BallSocketConstraint") or obj:IsA("HingeConstraint") then
                task.defer(function()
                    if obj and obj.Parent then
                        pcall(function() obj:Destroy() end)
                    end
                end)
                -- Also restore motors in case they were zeroed simultaneously
                ARG_restoreMotors(char)
            end
            -- Restore Motor6D if its MaxVelocity gets zeroed (frame after add)
            if obj:IsA("Motor6D") then
                task.defer(function()
                    if obj and obj.MaxVelocity == 0 then
                        obj.MaxVelocity = 0.1
                    end
                end)
            end
        end)

        -- Do a pass immediately in case the character already has injected pieces
        ARG_restoreMotors(char)
        ARG_removeInjectedConstraints(char)
    end

    -- Heartbeat loop: continuously enforce non-ragdoll state
    AntiFeatures_Connections.AntiRagdoll = RunService.Heartbeat:Connect(function()
        if not AntiFeatures_Enabled.AntiRagdoll then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        -- If somehow PlatformStand is still on, fix it
        if hum.PlatformStand then
            hum.PlatformStand = false
            hum.AutoRotate    = true
            ARG_restoreMotors(char)
        end
        -- Periodically ensure AutoRotate hasn't been disabled
        if not hum.AutoRotate then
            hum.AutoRotate = true
        end
    end)

    -- Re-bind on respawn
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        AntiRagdoll_BindCharacter(char)
    end)

    -- Bind for current character
    if LocalPlayer.Character then
        AntiRagdoll_BindCharacter(LocalPlayer.Character)
    end
end

