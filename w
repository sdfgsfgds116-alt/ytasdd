		-- IMPROVED NOTIFY  helper — expose typed notify on the tab itself
		-- Tab:Alert({ Type="success", Title="Done!", Desc="Saved." })
		-- (calls the parent window's Notify with colored accent)
		-- ═══════════════════════════════════════════════════════════════════
		Func.Alert = function(self, p)
			local typeLabels = {
				success = "✓ ",
				error   = "✕ ",
				warning = "⚠ ",
				info    = "ℹ ",
			}
			local typeColors = {
				success = Color3.fromRGB(60, 200, 100),
				error   = Color3.fromRGB(235, 60, 75),
				warning = Color3.fromRGB(240, 185, 30),
				info    = Color3.fromRGB(80, 160, 255),
			}
			local t = p.Type or 'info'
			local prefix = typeLabels[t] or ''
			local accentColor = typeColors[t]
			local origTitle = p.Title or ''
			-- Pass through to the window Notify if reachable; else do an inline notification
			-- We fire through the Tabs object stored in closure
			pcall(function()
				local notifTitle = '<font color="rgb(' ..
					math.floor(accentColor.R*255) .. ',' ..
					math.floor(accentColor.G*255) .. ',' ..
					math.floor(accentColor.B*255) .. ')">' ..
					prefix .. '</font>' .. origTitle
				Tabs:Notify({
					Title = notifTitle,
					Desc  = p.Desc  or p.Description or '',
					Time  = p.Time  or 4,
				})
			end)
		end

