-- ── RakNet bypass fallback: watch workspace for replicated BulletTrail parts ──
local rtRakNetConn = nil

local function rtRecoverOriginFromTrail(trail)
    -- Trail CFrame = CFrame.new(startPos, endPos) * CFrame.new(0,0,-dist/2)
    -- So center + lookVector*(+dist/2) = startPos  (Roblox look = -Z, so +Z goes backward toward start)
    local ok, pos = pcall(function()
        return (trail.CFrame * CFrame.new(0, 0, trail.Size.Z / 2)).Position
    end)
    return ok and pos or nil
end

local function rtFindShooterFallback(origin)
    -- Wider search: try tool Handle first, then HumanoidRootPart
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character; if not char then continue end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local h = item:FindFirstChild("Handle")
                if h then
                    local d = (h.Position - origin).Magnitude
                    if d < bestD then bestD = d; best = p end
                end
            end
        end
        -- Fallback to HRP when no equipped tool is close enough
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - origin).Magnitude
            if d < bestD then bestD = d; best = p end
        end
    end
    return (bestD <= 28) and best or nil   -- wider radius than ReplicateEvent path
end

local function rtOnBulletTrailAdded(inst)
    if not rtEnabled then return end
    if not (inst:IsA("Part") and inst.Name == "BulletTrail") then return end
    -- Exclude trails we fired ourselves
    local myChar = LocalPlayer.Character
    if myChar then
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        if myHRP then
            local ok2, trailPos = pcall(function() return inst.Position end)
            if ok2 and (myHRP.Position - trailPos).Magnitude < 15 then return end
        end
    end
    task.spawn(function()
        local origin = rtRecoverOriginFromTrail(inst)
        if not origin then return end
        -- Also recover endPos from the trail (local -Z direction from center)
        local endPos = nil
        pcall(function()
            endPos = (inst.CFrame * CFrame.new(0, 0, -inst.Size.Z / 2)).Position
        end)
        -- De-duplicate: skip if ReplicateEvent already logged this origin (within 2 studs)
        for i = #rtEntries, math.max(1, #rtEntries - 10), -1 do
            if (rtEntries[i].origin - origin).Magnitude < 2 then return end
        end
        -- Use the full resolver chain (including endpoint fallback for RakNet)
        local shooter = rtResolveShooter(origin, endPos)
        if not shooter or not rtShouldTrack(shooter) then return end
        if #rtEntries >= RT_MAX then table.remove(rtEntries, 1) end
        rtIdx += 1
        local entry = { idx = rtIdx, name = shooter.Name .. " [RN]", player = shooter, origin = origin }
        table.insert(rtEntries, entry)
        rtEspSpawn(origin, shooter.Name .. " [RN]")
        rtAddRow(entry)
        if rtCountLbl then rtCountLbl.Text = #rtEntries .. " shots" end
    end)
end

local function rtStartTracking()
    if rtEventConn  then rtEventConn:Disconnect();  rtEventConn  = nil end
    if rtRakNetConn then rtRakNetConn:Disconnect(); rtRakNetConn = nil end

    -- Primary: ReplicateEvent (normal shots)
    local ok, ev = pcall(function()
        return game:GetService("ReplicatedStorage"):WaitForChild("GunRemotes",10):WaitForChild("ReplicateEvent",10)
    end)
    if ok and ev then
        rtEventConn = ev.OnClientEvent:Connect(function(shots)
            if not rtEnabled or type(shots) ~= "table" then return end
            for _, shot in ipairs(shots) do
                if type(shot) ~= "table" or #shot < 2 then continue end
                local origin = shot[1]; local endPos = shot[2]
                if typeof(origin) ~= "Vector3" then continue end
                local shooter = rtResolveShooter(origin, typeof(endPos) == "Vector3" and endPos or nil)
                if not shooter or not rtShouldTrack(shooter) then continue end
                -- Determine if this bypassed the normal handle check (RakNet indicator)
                local handleClose = rtFindShooter(origin) ~= nil
                local tag = handleClose and shooter.Name or (shooter.Name .. " [RN]")
                if #rtEntries >= RT_MAX then table.remove(rtEntries, 1) end
                rtIdx += 1
                local entry = { idx = rtIdx, name = tag, player = shooter, origin = origin }
                table.insert(rtEntries, entry)
                rtEspSpawn(origin, tag)
                rtAddRow(entry)
                if rtCountLbl then rtCountLbl.Text = #rtEntries .. " shots" end
            end
        end)
    else
        PL_Notif("RT Position", "ReplicateEvent not found — RakNet fallback only")
    end

    -- Fallback: watch workspace for BulletTrail parts replicated from RakNet bypass shots
    rtRakNetConn = workspace.DescendantAdded:Connect(rtOnBulletTrailAdded)
end

local function rtStop()
    if rtEventConn  then rtEventConn:Disconnect();  rtEventConn  = nil end
    if rtRakNetConn then rtRakNetConn:Disconnect(); rtRakNetConn = nil end
end

