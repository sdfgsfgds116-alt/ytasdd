local InvisibleState = { enabled = false, savedPos = nil, heartbeat = nil }

local function InvisGetCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    local hum  = char:FindFirstChild("Humanoid")
    return char, hrp, hum
end

local function InvisTp(newCFrame)
    local _, hrp = InvisGetCharacter()
    if hrp then
        hrp.CFrame = typeof(newCFrame) == "Vector3" and CFrame.new(newCFrame) or newCFrame
    end
end

local function InvisEnable()
    -- Disconnect any leftover connections first
    if InvisibleState.heartbeat then
        InvisibleState.heartbeat:Disconnect()
        InvisibleState.heartbeat = nil
    end
    pcall(function() RunService:UnbindFromRenderStep("InvisCameraFix") end)

    InvisibleState.enabled = true

    -- Every physics step: save real position, then TP underground so server sees nothing
    InvisibleState.heartbeat = RunService.Heartbeat:Connect(function()
        if not InvisibleState.enabled then return end
        local _, hrp = InvisGetCharacter()
        if hrp then
            InvisibleState.savedPos = hrp.CFrame
            InvisTp(hrp.CFrame - Vector3.new(0, 6, 0))
        end
    end)

    -- Just before the camera renders: snap back to real position so the local client sees normally
    RunService:BindToRenderStep("InvisCameraFix", Enum.RenderPriority.Camera.Value - 1, function()
        if not InvisibleState.enabled then return end
        local _, hrp, hum = InvisGetCharacter()
        if InvisibleState.savedPos and hrp then
            InvisTp(InvisibleState.savedPos)
            InvisibleState.savedPos = nil
        end
        if hum then
            workspace.CurrentCamera.CameraType    = Enum.CameraType.Custom
            workspace.CurrentCamera.CameraSubject = hum
        end
    end)

    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Invisible",
        Text  = "You are now invisible!",
        Duration = 2,
    })
end

local function InvisDisable()
    InvisibleState.enabled = false

    if InvisibleState.heartbeat then
        InvisibleState.heartbeat:Disconnect()
        InvisibleState.heartbeat = nil
    end
    pcall(function() RunService:UnbindFromRenderStep("InvisCameraFix") end)

    -- Restore character to saved position if available
    pcall(function()
        if InvisibleState.savedPos then
            InvisTp(InvisibleState.savedPos)
            InvisibleState.savedPos = nil
        end
    end)

    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Invisible",
        Text  = "Visibility restored!",
        Duration = 2,
    })
end

