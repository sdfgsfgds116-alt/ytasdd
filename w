			IconLbl.LayoutOrder = 1
			IconLbl.BackgroundTransparency = 1
			IconLbl.BorderSizePixel = 0
			IconLbl.Font = Enum.Font.GothamBold
			IconLbl.Text = colData.icon
			IconLbl.TextColor3 = colData.accent
			IconLbl.TextSize = 12

