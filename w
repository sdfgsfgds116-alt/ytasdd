                btn.BackgroundColor3=Color3.fromRGB(40,40,40); btn.BackgroundTransparency=0.3
                btn.Text=txt; btn.TextColor3=Color3.fromRGB(255,255,255)
                btn.TextSize=24; btn.Font=Enum.Font.GothamBold; btn.ZIndex=300; btn.Parent=screenGui
                Instance.new("UICorner",btn).CornerRadius=UDim.new(0,12)
                return btn
            end
            local upBtn   = mkBtn("Up",   UDim2.new(1,-85,1,-230), "▲")
            local downBtn = mkBtn("Down", UDim2.new(1,-85,1,-150), "▼")
            upBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then CONTROL.Q=Env.cfg.vehicle.flySpeed*2; upBtn.BackgroundColor3=Color3.fromRGB(0,170,255) end end)
            upBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then CONTROL.Q=0; upBtn.BackgroundColor3=Color3.fromRGB(40,40,40) end end)
            downBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then CONTROL.E=-Env.cfg.vehicle.flySpeed*2; downBtn.BackgroundColor3=Color3.fromRGB(0,170,255) end end)
            downBtn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then CONTROL.E=0; downBtn.BackgroundColor3=Color3.fromRGB(40,40,40) end end)
        end
    end

