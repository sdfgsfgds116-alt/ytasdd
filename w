				KeyLbl.Size = UDim2.new(0.5, 0, 1, 0)
				KeyLbl.LayoutOrder = 1
				KeyLbl.BackgroundTransparency = 1
				KeyLbl.BorderSizePixel = 0
				KeyLbl.Font = Enum.Font.GothamBold
