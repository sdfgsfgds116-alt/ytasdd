            end
            if hrp then
                local p = hrp.Position
                lines[#lines+1] = string.format("Position: (%.1f, %.1f, %.1f)", p.X, p.Y, p.Z)
            end
        end

        -- All players
        lines[#lines+1] = ""
        lines[#lines+1] = "=== ALL PLAYERS IN SERVER ==="
        for _, p in ipairs(Players:GetPlayers()) do
            local pLine = "[" .. tostring(p.Name) .. "]"
            pLine = pLine .. " Team=" .. tostring(p.Team and p.Team.Name or "None")
            local char = p.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hum then
                    pLine = pLine .. string.format(" HP=%.0f/%.0f", hum.Health, hum.MaxHealth)
                    pLine = pLine .. " Speed=" .. tostring(hum.WalkSpeed)
                    pLine = pLine .. " State=" .. tostring(hum:GetState())
                end
                if hrp then
                    local pos = hrp.Position
                    pLine = pLine .. string.format(" Pos=(%.0f,%.0f,%.0f)", pos.X, pos.Y, pos.Z)
                end
                -- Check tools/weapons
                local tools = {}
                for _, item in ipairs(char:GetChildren()) do
                    if item:IsA("Tool") then tools[#tools+1] = item.Name end
                end
                if #tools > 0 then pLine = pLine .. " Holding=[" .. table.concat(tools, ",") .. "]" end
            else
                pLine = pLine .. " (no character/dead)"
            end
            lines[#lines+1] = pLine
        end

        -- Leaderboard stats
        lines[#lines+1] = ""
        lines[#lines+1] = "=== LEADERBOARD STATS ==="
        for _, p in ipairs(Players:GetPlayers()) do
            local leaderstats = p:FindFirstChild("leaderstats")
            if leaderstats then
                local stats = {}
                for _, v in ipairs(leaderstats:GetChildren()) do
                    stats[#stats+1] = v.Name .. "=" .. tostring(v.Value)
                end
                if #stats > 0 then
                    lines[#lines+1] = "[" .. p.Name .. "] " .. table.concat(stats, "  ")
                end
            end
        end
    end)

    if not ok then
        lines[#lines+1] = "(Some data unavailable: " .. tostring(err) .. ")"
    end
    return table.concat(lines, "\n")
end

-- ── Send via Groq API with live game context ──────────────────────────────────
local function ai_send(userText)
    userText = userText:match("^%s*(.-)%s*$")
    if userText == "" or ai_waiting then return end
    if ai_apiKey == "" then
        ai_addBubble("assistant", "Please enter your Groq API key in the Settings section below.\nGet one free (no credit card) at console.groq.com")
        return
    end

    ai_waiting = true
    table.insert(ai_history, { role = "user", content = userText })
    ai_addBubble("user", userText)

    local replyLbl = ai_addBubble("assistant", "● ● ●")
    if replyLbl then
        replyLbl.TextColor3 = AI_MUTED
        task.spawn(function()
            local dots = {"●", "● ●", "● ● ●"}
            local i = 1
            while ai_waiting and replyLbl and replyLbl.Parent do
                replyLbl.Text = dots[i]
                i = (i % #dots) + 1
                task.wait(0.4)
            end
        end)
    end

    task.spawn(function()
        local reply
        local ok, err = pcall(function()
            -- Build system prompt with live game data
            local gameCtx = ai_getGameContext()
            local systemPrompt = "You are an AI assistant embedded inside a Roblox game hub/exploit script. " ..
                "You have access to live game data shown below. Use it to answer questions about players, " ..
                "stats, positions, teams, health, weapons, and anything else in the game. " ..
                "Be concise and helpful. If asked to analyze a player, use the data provided.\n\n" ..
                gameCtx

            -- Build messages with system context injected fresh each call
            local messages = {{ role = "system", content = systemPrompt }}
            -- Append conversation history (skip any old system messages)
            for _, m in ipairs(ai_history) do
                if m.role ~= "system" then
                    messages[#messages+1] = m
                end
            end

            local payload = HttpService:JSONEncode({
                model    = "llama-3.3-70b-versatile",
                messages = messages,
            })
            local res = ai_post(
                "https://api.groq.com/openai/v1/chat/completions",
                {
                    ["Content-Type"]  = "application/json",
                    ["Authorization"] = "Bearer " .. ai_apiKey,
                },
                payload
            )
            if not res then
                reply = "Request failed. Make sure your executor supports HTTP (Synapse X, KRNL, Fluxus)."
                return
            end
            if res.StatusCode ~= 200 then
                local decoded, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
                if decoded and data and data.error then
                    reply = "API error " .. tostring(res.StatusCode) .. ": " .. tostring(data.error.message or data.error)
                else
                    reply = "API error " .. tostring(res.StatusCode) .. ". Check your API key."
                end
                return
            end
            local data = HttpService:JSONDecode(res.Body)
            if data and data.choices and data.choices[1]
                and data.choices[1].message and data.choices[1].message.content then
                reply = data.choices[1].message.content
            else
                reply = "Unexpected response format."
            end
        end)

        if not ok then reply = "Error: " .. tostring(err) end
        if not reply or reply == "" then reply = "No response received." end

        if replyLbl and replyLbl.Parent then
            replyLbl.Text       = reply
            replyLbl.TextColor3 = AI_TEXT
        end

        table.insert(ai_history, { role = "assistant", content = reply })
        ai_waiting = false
        ai_scrollBottom()
    end)
end

