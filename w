-- ============================================================================
-- SMITE (Utility > Player Actions)
-- Alternates the gun grip between +400 studs (sky) and -200 studs (ground)
-- every RenderStepped frame — bullets spawn from sky/ground alternately.
-- Suppresses all non-movement animations (gun-hold, arm-raise, tool equip)
-- exactly like Gun's True Range does, so the character looks natural.
-- ============================================================================

local Smite_Connections = {}
local _Smite_Tick       = false

local SMITE_ALLOWED_ANIMS = {"walk", "run", "idle", "jump", "fall", "land", "sit", "climb", "swim", "death", "die"}

local function smite_isAllowed(track)
    local name = track.Name:lower()
    for _, kw in ipairs(SMITE_ALLOWED_ANIMS) do
        if name:find(kw) then return true end
    end
    return false
end

local function smite_setGrip(desiredWorldCF)
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local rHand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
            if rHand then
                pcall(function()
                    tool.Grip = rHand.CFrame:Inverse() * desiredWorldCF
                end)
            end
        end
    end
end

local function smite_hookAnimator(char)
    pcall(function()
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if not animator then return end

        -- Kill all currently playing non-movement animations
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            if not smite_isAllowed(track) then track:Stop(0) end
        end

        -- Kill any non-movement animation the instant it tries to play
        if Smite_Connections.animPlayed then
            pcall(function() Smite_Connections.animPlayed:Disconnect() end)
        end
        Smite_Connections.animPlayed = animator.AnimationPlayed:Connect(function(track)
            if not smite_isAllowed(track) then
                track:Stop(0)
            end
        end)
    end)
end

local function startSmite()
    if Smite_Connections.render then return end
    _Smite_Tick = false

    -- Hook animator on current character
    if LocalPlayer.Character then smite_hookAnimator(LocalPlayer.Character) end

    -- Re-hook on respawn
    Smite_Connections.animSuppressor = LocalPlayer.CharacterAdded:Connect(function(char)
        local hum = char:WaitForChild("Humanoid", 10)
        if not hum then return end
        local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 10)
        if not animator then return end
        task.wait(0.1)
        smite_hookAnimator(char)
    end)

    -- Grip loop
    Smite_Connections.render = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        _Smite_Tick = not _Smite_Tick
        local yOff = _Smite_Tick and 400 or -200
        smite_setGrip(CFrame.new(hrp.Position + Vector3.new(0, yOff, 0)))
    end)
end

local function stopSmite()
    -- Disconnect all connections
    for k, conn in pairs(Smite_Connections) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
        Smite_Connections[k] = nil
    end

    -- Reset tool grips
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        for _, c in ipairs(char:GetChildren()) do
            if c:IsA("Tool") then
                pcall(function() c.Grip = CFrame.new(0, 0, 0) end)
            end
        end
    end)
end

