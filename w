			MsgLbl.Size = UDim2.new(Dismissable and 0.82 or 0.9, 0, 1, 0)
			MsgLbl.LayoutOrder = 2
			MsgLbl.BackgroundTransparency = 1
			MsgLbl.BorderSizePixel = 0
			MsgLbl.Font = Enum.Font.Gotham
			MsgLbl.Text = tostring(Message)
			MsgLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
