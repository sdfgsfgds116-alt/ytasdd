            for _, f in ipairs(listfiles(CONFIG_DIR) or {}) do
                local name = f:match('[^/\\]+$') or f
                name = name:gsub(CONFIG_EXT .. '$', '')
                if name ~= '' then table.insert(list, name) end
            end
        end
    end)
    if #list == 0 then list = { 'default' } end
    return list
end

local function _buildSnapshot()
    -- Capture current combat + visual settings from Env.cfg
    local ok, data = pcall(function()
        return {
            cfg       = Env and Env.cfg or {},
            theme     = SaveTheme and '_saved_' or 'Amethyst',
            logo      = Window and '_current_' or 'spiral',
        }
    end)
    if ok then return data end
    return {}
end

local function _saveConfig(name)
    pcall(function()
        if not isfolder(CONFIG_DIR) then makefolder(CONFIG_DIR) end
        local snap = _buildSnapshot()
        local encoded = game:GetService('HttpService'):JSONEncode(snap)
        if writefile then writefile(_cfgPath(name), encoded) end
        Window:Notify({ Title = 'Config Saved', Desc = 'Saved as "' .. name .. '"', Time = 3 })
    end)
end

local function _loadConfig(name)
    pcall(function()
        if not isfile(_cfgPath(name)) then
            Window:Notify({ Title = 'Config Load', Desc = 'No config named "' .. name .. '" found.', Time = 3 })
            return
        end
        local raw = readfile(_cfgPath(name))
        local data = game:GetService('HttpService'):JSONDecode(raw)
        -- Restore Env.cfg fields
        if data.cfg and Env and Env.cfg then
            for k, v in pairs(data.cfg) do
                if Env.cfg[k] ~= nil then
                    Env.cfg[k] = v
                end
            end
        end
        currentCfgName = name
        Window:Notify({ Title = 'Config Loaded', Desc = 'Loaded "' .. name .. '"', Time = 3 })
    end)
end

local function _deleteConfig(name)
    pcall(function()
        if isfile(_cfgPath(name)) then
            delfile(_cfgPath(name))
            Window:Notify({ Title = 'Config Deleted', Desc = 'Deleted "' .. name .. '"', Time = 3 })
        end
    end)
end

