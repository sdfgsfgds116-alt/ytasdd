			HeaderBg.Size = UDim2.new(1, 0, 1, 0)
			addToTheme('Page', HeaderBg)
			Instance.new("UICorner", HeaderBg).CornerRadius = UDim.new(0, 6)

			-- Left accent
			if Accent then
				local AccL = Instance.new("Frame", HeaderBg)
				AccL.AnchorPoint = Vector2.new(0, 0.5)
				AccL.BackgroundColor3 = Accent
				AccL.BorderSizePixel = 0
				AccL.Position = UDim2.new(0, 0, 0.5, 0)
				AccL.Size = UDim2.new(0, 3, 0.6, 0)
				Instance.new("UICorner", AccL).CornerRadius = UDim.new(1, 0)
			end

			local HeaderLL = Instance.new("UIListLayout", HeaderBg)
			HeaderLL.FillDirection = Enum.FillDirection.Horizontal
			HeaderLL.VerticalAlignment = Enum.VerticalAlignment.Center
			HeaderLL.SortOrder = Enum.SortOrder.LayoutOrder
			local HeaderPad = Instance.new("UIPadding", HeaderBg)
			HeaderPad.PaddingLeft = UDim.new(0, Accent and 10 or 8)
			HeaderPad.PaddingRight = UDim.new(0, 8)

			local ChevronLbl = Instance.new("TextLabel", HeaderBg)
			ChevronLbl.Size = UDim2.new(0, 12, 1, 0)
			ChevronLbl.LayoutOrder = 1
			ChevronLbl.BackgroundTransparency = 1
			ChevronLbl.BorderSizePixel = 0
			ChevronLbl.Font = Enum.Font.GothamBold
			ChevronLbl.Text = OpenDef and "▾" or "▸"
			ChevronLbl.TextColor3 = Color3.fromRGB(200, 190, 240)
			ChevronLbl.TextSize = 12
			ChevronLbl.TextXAlignment = Enum.TextXAlignment.Center
			addToTheme('Text & Icon', ChevronLbl)

			local SectionTitleLbl = Instance.new("TextLabel", HeaderBg)
			SectionTitleLbl.Size = UDim2.new(1, -24, 1, 0)
			SectionTitleLbl.LayoutOrder = 2
			SectionTitleLbl.BackgroundTransparency = 1
			SectionTitleLbl.BorderSizePixel = 0
			SectionTitleLbl.Font = Enum.Font.GothamBold
			SectionTitleLbl.Text = tostring(Title)
			SectionTitleLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
			SectionTitleLbl.TextTransparency = 0.2
			SectionTitleLbl.TextSize = 11
			SectionTitleLbl.TextXAlignment = Enum.TextXAlignment.Left
			addToTheme('Text & Icon', SectionTitleLbl)

			-- Content container
			local ContentFrame = Instance.new("Frame", ScrollingFrame_1)
			ContentFrame.Name = "CollapsibleContent"
			ContentFrame.BackgroundTransparency = 1
			ContentFrame.BorderSizePixel = 0
			ContentFrame.Size = UDim2.new(1, 0, 0, 0)
			ContentFrame.ClipsDescendants = true
			ContentFrame.Visible = OpenDef

			local ContentSF = Instance.new("Frame", ContentFrame)
			ContentSF.BackgroundTransparency = 1
			ContentSF.BorderSizePixel = 0
			ContentSF.Size = UDim2.new(1, 0, 0, 0)
			ContentSF.AutomaticSize = Enum.AutomaticSize.Y

			local ContentLL = Instance.new("UIListLayout", ContentSF)
			ContentLL.SortOrder = Enum.SortOrder.LayoutOrder
			ContentLL.Padding = UDim.new(0, 5)
			local ContentPad = Instance.new("UIPadding", ContentSF)
			ContentPad.PaddingLeft = UDim.new(0, 6)

			local _isOpen = OpenDef
			local _targetH = 0

			local function updateContentHeight()
				task.defer(function()
					_targetH = ContentLL.AbsoluteContentSize.Y + 8
					if _isOpen then
						ContentFrame.Size = UDim2.new(1, 0, 0, _targetH)
					end
				end)
			end

			ContentLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateContentHeight)

			local function toggle()
				_isOpen = not _isOpen
				ChevronLbl.Text = _isOpen and "▾" or "▸"
				if _isOpen then
					ContentFrame.Visible = true
					ContentFrame.Size = UDim2.new(1, 0, 0, 0)
					tw({v = ContentFrame, t = 0.2, s = Enum.EasingStyle.Exponential, d = "Out",
						g = {Size = UDim2.new(1, 0, 0, _targetH)}}):Play()
				else
					local tf = tw({v = ContentFrame, t = 0.18, s = Enum.EasingStyle.Exponential, d = "Out",
						g = {Size = UDim2.new(1, 0, 0, 0)}})
					tf:Play()
					tf.Completed:Connect(function()
						if not _isOpen then ContentFrame.Visible = false end
					end)
				end
			end

			local HeaderClick = click(HeaderBg)
			HeaderClick.MouseButton1Click:Connect(toggle)

			delay(0.15, updateContentHeight)

			-- The inner Func table — same API as a Tab's Func, but parented to ContentSF
			local InnerFunc = {}

