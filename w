				KeyLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
				KeyLbl.TextTransparency = 0.5
				KeyLbl.TextSize = 10
				KeyLbl.TextXAlignment = Enum.TextXAlignment.Left
				KeyLbl.TextTruncate = Enum.TextTruncate.AtEnd
