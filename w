-- Each feature lives in its own do...end scope to avoid hitting Lua's
-- 200-local-register limit. Public functions are exported via getgenv().
-- ============================================================================

do -- shared helper
    local function getLocalVehicle()
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hum and hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
            return hum.SeatPart.Parent, hum.SeatPart
        end
        return nil, nil
    end
    getgenv().VE_getLocalVehicle = getLocalVehicle
end

do -- Vehicle Invisibility
    local enabled   = false
    local origTrans = {}
    local conn      = nil
    local level     = 1

    local function apply(model, transparency)
        if not model then return end
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("UnionOperation") then
                if transparency == nil then
                    if origTrans[part] ~= nil then
                        part.Transparency = origTrans[part]
                        origTrans[part] = nil
                    end
                else
                    if origTrans[part] == nil then origTrans[part] = part.Transparency end
                    part.Transparency = transparency
                end
            end
        end
    end

    getgenv().VE_setInvisLevel = function(v) level = v end

    getgenv().startVehicleInvis = function()
        enabled = true
        conn = RunService.Heartbeat:Connect(function()
            local model = getgenv().VE_getLocalVehicle()
            if model then apply(model, level) end
        end)
    end

    getgenv().stopVehicleInvis = function()
        enabled = false
        if conn then conn:Disconnect(); conn = nil end
        local model = getgenv().VE_getLocalVehicle()
        if model then apply(model, nil) end
        origTrans = {}
    end
end

do -- Vehicle Noclip
    local enabled = false
    local orig    = {}
    local conn    = nil

    getgenv().startVehicleNoclip = function()
        enabled = true
        conn = RunService.Heartbeat:Connect(function()
            local model = getgenv().VE_getLocalVehicle()
            if not model then return end
            for _, part in ipairs(model:GetDescendants()) do
                if part:IsA("BasePart") then
                    if orig[part] == nil then orig[part] = part.CanCollide end
                    part.CanCollide = false
                end
            end
        end)
    end

    getgenv().stopVehicleNoclip = function()
        enabled = false
        if conn then conn:Disconnect(); conn = nil end
        for part, v in pairs(orig) do pcall(function() part.CanCollide = v end) end
        orig = {}
    end
end

do -- Nitro Boost
    local mult     = 3
    local duration = 2
    local cooldown = 5
    local onCooldown = false
    local inputConn  = nil

    getgenv().VE_setNitroMult     = function(v) mult     = v end
    getgenv().VE_setNitroDuration = function(v) duration = v end
    getgenv().VE_setNitroCooldown = function(v) cooldown = v end

    getgenv().doNitroBoost = function()
        if onCooldown then Window:Notify({ Title="Nitro", Desc="On cooldown!", Time=1 }); return end
        local model, seat = getgenv().VE_getLocalVehicle()
        if not seat then Window:Notify({ Title="Nitro", Desc="Not in a vehicle", Time=2 }); return end
        onCooldown = true

        -- Apply boost via direct velocity impulse on the vehicle's primary part (or seat itself)
        local rootPart = (model and model.PrimaryPart) or seat
        local boostSteps = math.max(1, math.floor(duration / 0.05))
        local stepCount = 0
        local boostConn
        boostConn = RunService.Heartbeat:Connect(function()
            stepCount = stepCount + 1
            if stepCount > boostSteps then
                boostConn:Disconnect()
                return
            end
            pcall(function()
                local lookVec = rootPart.CFrame.LookVector
                rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity
                    + lookVec * (mult * 8)
            end)
        end)

        Window:Notify({ Title="Nitro", Desc=("Boost! x%d for %ds"):format(mult, duration), Time=duration })
        task.delay(cooldown, function()
            onCooldown = false
            Window:Notify({ Title="Nitro", Desc="Ready!", Time=1 })
        end)
    end

    getgenv().startNitro = function()
        inputConn = game:GetService("UserInputService").InputBegan:Connect(function(inp, processed)
            if processed then return end
            if inp.KeyCode == Enum.KeyCode.N then getgenv().doNitroBoost() end
        end)
    end

    getgenv().stopNitro = function()
        if inputConn then inputConn:Disconnect(); inputConn = nil end
    end
end

do -- Vehicle Color
    local enabled  = false
    local color    = Color3.fromRGB(255, 50, 50)
    local origCol  = {}
    local conn     = nil

    local function apply(model, c)
        if not model then return end
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("UnionOperation") then
                if c == nil then
                    if origCol[part] ~= nil then part.Color = origCol[part]; origCol[part] = nil end
                else
                    if origCol[part] == nil then origCol[part] = part.Color end
                    part.Color = c
                end
            end
        end
    end

    getgenv().VE_setVehicleColor = function(v) color = v end

    getgenv().startVehicleColor = function()
        enabled = true
        conn = RunService.Heartbeat:Connect(function()
            local model = getgenv().VE_getLocalVehicle()
            if model then apply(model, color) end
        end)
    end

    getgenv().stopVehicleColor = function()
        enabled = false
        if conn then conn:Disconnect(); conn = nil end
        local model = getgenv().VE_getLocalVehicle()
        if model then apply(model, nil) end
        origCol = {}
    end
end

do -- Auto-Brake
    local inputConn = nil

    getgenv().doAutoBrake = function()
        local model, seat = getgenv().VE_getLocalVehicle()
        if not seat then return end
        -- Zero out velocity on the vehicle's primary part or the seat itself
        local rootPart = (model and model.PrimaryPart) or seat
        pcall(function()
            rootPart.AssemblyLinearVelocity  = Vector3.zero
            rootPart.AssemblyAngularVelocity = Vector3.zero
        end)
        Window:Notify({ Title="Auto-Brake", Desc="Braked!", Time=1 })
    end

    getgenv().startAutoBrake = function()
        inputConn = game:GetService("UserInputService").InputBegan:Connect(function(inp, processed)
            if processed then return end
            if inp.KeyCode == Enum.KeyCode.B then getgenv().doAutoBrake() end
        end)
    end

    getgenv().stopAutoBrake = function()
        if inputConn then inputConn:Disconnect(); inputConn = nil end
    end
end

