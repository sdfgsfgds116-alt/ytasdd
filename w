				local CellPad = Instance.new("UIPadding", Cell)
				CellPad.PaddingLeft = UDim.new(0, 6); CellPad.PaddingRight = UDim.new(0, 6)
				local CellLL = Instance.new("UIListLayout", Cell)
				CellLL.FillDirection = Enum.FillDirection.Horizontal
				CellLL.VerticalAlignment = Enum.VerticalAlignment.Center
				CellLL.HorizontalAlignment = Enum.HorizontalAlignment.Left
				CellLL.SortOrder = Enum.SortOrder.LayoutOrder
				CellLL.Padding = UDim.new(0, 4)
