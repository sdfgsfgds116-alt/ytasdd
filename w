-- ── One scanner tick: diff snapshots and raise alerts ────────────────────────
local function ai_scanTick()
    if not ai_scannerEnabled then return end
    local Players = game:GetService("Players")
    local now     = tick()
    local alerts  = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p == Players.LocalPlayer then continue end
        local uid  = p.UserId
        local prev = ai_prevSnapshots[uid]
        local char = p.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")

        local curHp    = hum  and hum.Health         or 0
        local maxHp    = hum  and hum.MaxHealth       or 100
        local curSpeed = hum  and hum.WalkSpeed       or 0
        local curPosV  = hrp  and hrp.Position        or Vector3.new(0,0,0)
        local curPos   = {x = curPosV.X, y = curPosV.Y, z = curPosV.Z}

        -- Leaderboard kills/cash for spike detection
        local kills = 0
        local ls = p:FindFirstChild("leaderstats")
        if ls then
            for _, v in ipairs(ls:GetChildren()) do
                local n = v.Name:lower()
                if n:find("kill") or n:find("score") then kills = tonumber(v.Value) or 0 end
            end
        end

        if prev then
            -- Speed hack
            if curSpeed > SPEED_THRESHOLD then
                alerts[#alerts+1] = string.format(
                    "[%s] has WalkSpeed %.0f (normal max is %d) — possible speed hack.",
                    p.Name, curSpeed, SPEED_THRESHOLD)
            end

            -- Teleport (large sudden position change while not dead)
            if curHp > 0 and prev.hp > 0 then
                local dx = curPosV.X - prev.px
                local dz = curPosV.Z - prev.pz
                local dist = math.sqrt(dx*dx + dz*dz)
                if dist > TP_THRESHOLD then
                    alerts[#alerts+1] = string.format(
                        "[%s] moved %.0f studs in %d seconds — possible teleport hack.",
                        p.Name, dist, SCAN_INTERVAL)
                end
            end

            -- Fly detection (very high Y and not jumping naturally)
            if curPosV.Y > (prev.groundY or 0) + FLY_Y_THRESHOLD and curHp > 0 then
                alerts[#alerts+1] = string.format(
                    "[%s] is %.0f studs above ground (Y=%.0f) — possible fly hack.",
                    p.Name, curPosV.Y - (prev.groundY or 0), curPosV.Y)
            end

            -- Sudden health regen (healed more than 30 HP while not max)
            local hpGain = curHp - prev.hp
            if hpGain > 30 and curHp < maxHp then
                alerts[#alerts+1] = string.format(
                    "[%s] regained %.0f HP instantly (%.0f → %.0f) — possible god-mode or health hack.",
                    p.Name, hpGain, prev.hp, curHp)
            end

            -- Kill spike: gained 3+ kills in one interval
            if kills > 0 and prev.kills > 0 and (kills - prev.kills) >= 3 then
                alerts[#alerts+1] = string.format(
                    "[%s] got %d kills in ~%d seconds — possible kill-all or combat exploit.",
                    p.Name, kills - prev.kills, SCAN_INTERVAL)
            end
        end

        -- Store snapshot
        ai_prevSnapshots[uid] = {
            hp      = curHp,
            px      = curPosV.X,
            py      = curPosV.Y,
            pz      = curPosV.Z,
            groundY = math.min(curPosV.Y, prev and prev.groundY or curPosV.Y),
            speed   = curSpeed,
            kills   = kills,
        }
    end

    -- Clean up snapshots for players who left
    for uid, _ in pairs(ai_prevSnapshots) do
        local found = false
        for _, p in ipairs(Players:GetPlayers()) do
            if p.UserId == uid then found = true; break end
        end
        if not found then ai_prevSnapshots[uid] = nil end
    end

    -- Fire alerts (batch into one message if multiple)
    if #alerts > 0 then
        local msg = "LIVE SCAN ALERT:\n"
        for i, a in ipairs(alerts) do msg = msg .. i .. ". " .. a .. "\n" end
        ai_scannerAsk(msg:match("^(.-)%s*$"))  -- trim trailing newline
    end

    -- Periodic full-scan summary
    if (now - ai_lastFullScan) >= FULLSCAN_INTERVAL then
        ai_lastFullScan = now
        task.delay(0.5, function()
            ai_scannerAsk("Give me a brief status report of all players in the server right now — who looks clean, who looks suspicious, and any notable observations. Keep it under 6 bullet points.")
        end)
    end
end

