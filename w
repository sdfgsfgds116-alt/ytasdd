			RFL.VerticalAlignment = Enum.VerticalAlignment.Center
			RFL.SortOrder = Enum.SortOrder.LayoutOrder
			RFL.Padding = UDim.new(0, 5)
			local RFP = Instance.new("UIPadding", RF)
			RFP.PaddingRight = UDim.new(0, 10)

			local btnRefs = {}
			for idx, btnData in ipairs(Buttons) do
				local label    = btnData.Label    or btnData.Title or tostring(idx)
				local cb       = btnData.Callback or function() end
				local btnColor = btnData.Color    or Color3.fromRGB(91, 68, 209)
				local btnHover = btnData.HoverColor or Color3.fromRGB(110, 85, 240)

				local BF = Instance.new("Frame", RF)
				BF.BackgroundColor3 = btnColor
				BF.BorderSizePixel = 0
				BF.Size = UDim2.new(0, 0, 1, 0)
				BF.AutomaticSize = Enum.AutomaticSize.X
				BF.LayoutOrder = idx
				BF.ClipsDescendants = true
				Instance.new("UICorner", BF).CornerRadius = UDim.new(0, 6)
				local BPad = Instance.new("UIPadding", BF)
				BPad.PaddingLeft = UDim.new(0, 10); BPad.PaddingRight = UDim.new(0, 10)
				local BLL = Instance.new("UIListLayout", BF)
				BLL.FillDirection = Enum.FillDirection.Horizontal
				BLL.VerticalAlignment = Enum.VerticalAlignment.Center
				BLL.HorizontalAlignment = Enum.HorizontalAlignment.Center
				BLL.SortOrder = Enum.SortOrder.LayoutOrder
				local BL = Instance.new("TextLabel", BF)
				BL.Size = UDim2.new(0, 0, 1, 0)
				BL.AutomaticSize = Enum.AutomaticSize.X
				BL.BackgroundTransparency = 1
				BL.BorderSizePixel = 0
				BL.Font = Enum.Font.GothamBold
				BL.Text = tostring(label)
				BL.TextColor3 = Color3.fromRGB(255, 255, 255)
				BL.TextSize = 10

				local BClick = click(BF)
				local ti = TweenInfo.new(0.1)
				BClick.MouseEnter:Connect(function()
					tw({v = BF, t = 0.1, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundColor3 = btnHover}}):Play()
				end)
				BClick.MouseLeave:Connect(function()
					tw({v = BF, t = 0.1, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundColor3 = btnColor}}):Play()
				end)
				BClick.MouseButton1Down:Connect(function()
					BF.AnchorPoint = Vector2.new(0.5, 0.5)
					tw({v = BF, t = 0.08, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0, BF.AbsoluteSize.X - 4, 0.85, 0)}}):Play()
				end)
				BClick.MouseButton1Up:Connect(function()
					tw({v = BF, t = 0.08, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0, 0, 1, 0), AutomaticSize = Enum.AutomaticSize.X}}):Play()
				end)
				BClick.MouseButton1Click:Connect(function()
					jc(BClick, BF)
					pcall(cb)
				end)
				btnRefs[label] = { frame = BF, label = BL }
			end

			local New = {}
			function New:SetButtonLabel(old, new)
				if btnRefs[old] then
					btnRefs[old].label.Text = new
					btnRefs[new] = btnRefs[old]
					btnRefs[old] = nil
				end
			end
			function New:SetTitle(t) Config:SetTitle(t) end
			function New:SetDesc(t) Config:SetDesc(t) end
			function New:SetVisible(t) MBBg.Parent.Visible = t end
			return New
		end

