-- Strategy 1: tool Handle within strict radius (normal shots)
local function rtFindShooter(origin)
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character; if not char then continue end
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local h = item:FindFirstChild("Handle")
                if h then local d = (h.Position - origin).Magnitude; if d < bestD then bestD = d; best = p end end
            end
        end
    end
    return (bestD <= 10) and best or nil
end

-- Strategy 2: HRP proximity with wider radius (RakNet / spoofed origin fallback)
local function rtFindShooterByHRP(origin)
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character; if not char then continue end
        -- Check tool handle first (wider radius than strategy 1)
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local h = item:FindFirstChild("Handle")
                if h then
                    local d = (h.Position - origin).Magnitude
                    if d < bestD then bestD = d; best = p end
                end
            end
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - origin).Magnitude
            if d < bestD then bestD = d; best = p end
        end
    end
    return (bestD <= 40) and best or nil
end

-- Strategy 3: ray-cast along shot direction — finds who is standing closest to the
-- line from origin toward endPos.
-- NOTE: the `along < -5` guard is intentionally removed here because RakNet bypass
-- shots use a spoofed (fake) origin that can be anywhere on the map, meaning the
-- real shooter will often appear "behind" the fake origin along the ray direction.
-- We only reject players who are wildly past the endpoint (>60 studs beyond).
local function rtFindShooterByRay(origin, endPos)
    if typeof(endPos) ~= "Vector3" then return nil end
    local dir = (endPos - origin)
    local len = dir.Magnitude
    if len < 0.1 then return nil end
    local unit = dir.Unit
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character; if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then continue end
        local toP = hrp.Position - origin
        local along = toP:Dot(unit)
        -- Only skip players way past the bullet endpoint (they can't be the shooter)
        if along > len + 60 then continue end
        local perp = (toP - unit * along).Magnitude
        if perp < bestDist then bestDist = perp; best = p end
    end
    return (bestDist <= 20) and best or nil  -- widened from 12 → 20 studs
end

-- Strategy 4: endpoint-based reverse trace — specifically targets RakNet bypass where
-- the origin is completely fabricated. Finds an armed player whose character is facing
-- toward endPos (the real bullet landing point) from a plausible shooting distance.
local function rtFindShooterByEndpoint(endPos)
    if typeof(endPos) ~= "Vector3" then return nil end
    local best, bestScore = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character; if not char then continue end
        -- Must have a gun/tool equipped — unarmed players can't be the shooter
        local armed = false
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then armed = true; break end
        end
        if not armed then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then continue end
        local toEnd = endPos - hrp.Position
        local dist  = toEnd.Magnitude
        if dist < 2 then continue end  -- this player IS at the impact point (victim)
        -- Dot product of the player's look direction vs direction to endpoint
        local lookDot = hrp.CFrame.LookVector:Dot(toEnd.Unit)
        -- Score: favour close + well-aimed players. lookDot in [-1,1]; map to (0,1]
        local score = dist / math.max(0.01, (lookDot + 1) * 0.5)
        if score < bestScore then bestScore = score; best = p end
    end
    -- Conservative threshold: only accept if score is low enough to be plausible
    return (bestScore < 300) and best or nil
end

-- Master resolver: tries all 4 strategies in order
local function rtResolveShooter(origin, endPos)
    return rtFindShooter(origin)
        or rtFindShooterByHRP(origin)
        or (endPos and rtFindShooterByRay(origin, endPos))
        or (endPos and rtFindShooterByEndpoint(endPos))
        or nil
end

local function rtShouldTrack(p)
    if not p then return false end
    if rtMode == "All" then return true
    elseif rtMode == "Single" then return rtSingleName ~= "" and p.Name == rtSingleName
    elseif rtMode == "Selected" then return rtSelNames[p.Name] == true end
    return false
end

