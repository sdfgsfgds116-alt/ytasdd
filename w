-- Add one chat row to the scroll list
local function clAddEntry(playerName, message)
    if not clScrollRef then return end
    pcall(function()
        clIdx += 1
        if clEmptyRef2 then clEmptyRef2.Visible = false end
        if #clRows >= clMax then
            local oldest = table.remove(clRows, 1)
            if oldest and oldest.Parent then oldest:Destroy() end
        end

        local ts      = os.date("%H:%M:%S")
        local isLocal = (playerName == LocalPlayer.Name)
        local rowBg   = (clIdx % 2 == 0) and CNC_ROW_EVEN or CNC_ROW_ODD
        local nameCol = isLocal and CL_SELF_NAME or CL_OTHER_NAME

        local row = Instance.new("Frame", clScrollRef)
        row.Size = UDim2.new(1, 0, 0, 32)
        row.BackgroundColor3 = rowBg
        row.BorderSizePixel = 0; row.LayoutOrder = clIdx
        row.ZIndex = 4; row.ClipsDescendants = true
        makeCorner(row, 5); makeStroke(row, Color3.fromRGB(38, 28, 65), 1)
        row.MouseEnter:Connect(function()  row.BackgroundColor3 = CNC_HOVER  end)
        row.MouseLeave:Connect(function()  row.BackgroundColor3 = rowBg      end)

        -- Left accent bar (blue for self, purple for others)
        local ac = Instance.new("Frame", row)
        ac.Size = UDim2.new(0, 3, 1, -6)
        ac.Position = UDim2.new(0, 0, 0.5, 0); ac.AnchorPoint = Vector2.new(0, 0.5)
        ac.BackgroundColor3 = isLocal and CL_SELF_NAME or CNC_ACCENT
        ac.BorderSizePixel = 0; ac.ZIndex = 6; makeCorner(ac, 3)

        -- Timestamp (top-left)
        local tsLbl = Instance.new("TextLabel", row)
        tsLbl.Size = UDim2.new(0, 62, 0, 14); tsLbl.Position = UDim2.new(0, 8, 0, 2)
        tsLbl.BackgroundTransparency = 1; tsLbl.Text = ts
        tsLbl.TextColor3 = CL_TIME_COL; tsLbl.TextSize = 9
        tsLbl.Font = Enum.Font.Gotham
        tsLbl.TextXAlignment = Enum.TextXAlignment.Left; tsLbl.ZIndex = 5

        -- Player name (bottom-left)
        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Size = UDim2.new(0, 118, 0, 14); nameLbl.Position = UDim2.new(0, 8, 0, 16)
        nameLbl.BackgroundTransparency = 1; nameLbl.Text = playerName
        nameLbl.TextColor3 = nameCol; nameLbl.TextSize = 10
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd; nameLbl.ZIndex = 5

        -- Message body (right side, vertically centred)
        local msgLbl = Instance.new("TextLabel", row)
        msgLbl.Size = UDim2.new(1, -138, 1, 0); msgLbl.Position = UDim2.new(0, 134, 0, 0)
        msgLbl.BackgroundTransparency = 1; msgLbl.Text = message
        msgLbl.TextColor3 = CL_MSG_COL; msgLbl.TextSize = 10
        msgLbl.Font = Enum.Font.Gotham
        msgLbl.TextXAlignment = Enum.TextXAlignment.Left
        msgLbl.TextYAlignment = Enum.TextYAlignment.Center
        msgLbl.TextTruncate = Enum.TextTruncate.AtEnd
        msgLbl.ZIndex = 5; msgLbl.ClipsDescendants = true

        table.insert(clRows, row)
        if clCountRef then clCountRef.Text = #clRows .. " msgs" end
        task.defer(function()
            if clScrollRef then clScrollRef.CanvasPosition = Vector2.new(0, math.huge) end
        end)
    end)
end

-- Connect a single player's Chatted signal
local function clConnectPlayer(p)
    if clConns[p] then return end
    clConns[p] = p.Chatted:Connect(function(msg)
        if clEnabled then clAddEntry(p.Name, msg) end
    end)
end

local function clConnectAll()
    for _, p in ipairs(Players:GetPlayers()) do clConnectPlayer(p) end
end

