                    if d < CT.dodgeRadius then
                        CT.dodgeCooldown = tick() + CT.dodgeCD
                        local awayDir = (myHRP.Position - obj.Position)
                        if awayDir.Magnitude < 0.01 then awayDir = Vector3.new(1, 0, 0) end
                        awayDir = Vector3.new(awayDir.X, 0, awayDir.Z).Unit
                        pcall(function()
                            myHRP.CFrame = myHRP.CFrame + awayDir * CT.dodgeDist
                        end)
                        if CT.dodgeNotify then
