        local PlayersSvc = game:GetService("Players")
        local hitModel = target:FindFirstAncestorOfClass("Model") or target.Parent
        if not hitModel then return nil end

        -- Covers both part.Parent == Character and deeper descendants.
        local p = PlayersSvc:GetPlayerFromCharacter(hitModel)
        if p then return p end
        if target.Parent and target.Parent.Parent then
            p = PlayersSvc:GetPlayerFromCharacter(target.Parent.Parent)
            if p then return p end
        end
        return nil
    end

