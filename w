do
    local _UWB_enabled    = false
    local _UWB_stash      = {}
    local _UWB_plugs      = {}
    local _UWB_heartbeat  = nil

    local _UWB_Players    = game:GetService("Players")
    local _UWB_RunService = game:GetService("RunService")
    local _UWB_nih        = _UWB_Players.LocalPlayer

    local function _UWB_grabRoot(char)
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function _UWB_saveOriginal(plr, root)
        if _UWB_stash[plr] then return end
        _UWB_stash[plr] = {
            size         = root.Size,
            transparency = root.Transparency,
            shape        = root.Shape,
            material     = root.Material,
        }
    end

    local function _UWB_smack(plr)
        if plr == _UWB_nih then return end
        local char = plr.Character
        local root = _UWB_grabRoot(char)
        if not root then return end
        _UWB_saveOriginal(plr, root)
        root.CanCollide  = false
        root.Size        = Vector3.new(15, 15, 15)
        root.Transparency = 0.5
        root.Material    = Enum.Material.ForceField
        root.Shape       = Enum.PartType.Block
    end

    local function _UWB_unsmack(plr)
        local data = _UWB_stash[plr]
        if not data then return end
        local char = plr.Character
        local root = _UWB_grabRoot(char)
        if root then
            root.Size        = data.size
            root.Transparency = data.transparency
            root.Shape       = data.shape
            root.Material    = data.material
        end
        _UWB_stash[plr] = nil
    end

    local function _UWB_hideMyHRP()
        local char = _UWB_nih.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Transparency = 1
            hrp.LocalTransparencyModifier = 1
        end
    end

    local function _UWB_hookPlr(plr)
        if _UWB_plugs[plr] then return end
        _UWB_plugs[plr] = {}
        _UWB_plugs[plr].spawn = plr.CharacterAdded:Connect(function()
            task.wait(0.15)
            _UWB_smack(plr)
        end)
        if plr.Character then
            task.wait(0.15)
            _UWB_smack(plr)
        end
    end

    local function _UWB_unhookPlr(plr)
        _UWB_unsmack(plr)
        if _UWB_plugs[plr] then
            for _, conn in pairs(_UWB_plugs[plr]) do conn:Disconnect() end
            _UWB_plugs[plr] = nil
        end
    end

    local _UWB_playerAddedConn   = nil
    local _UWB_playerRemovingConn = nil
    local _UWB_charAddedConn     = nil

    local function _UWB_enable()
        -- Hook all current players
        for _, plr in ipairs(_UWB_Players:GetPlayers()) do
            _UWB_hookPlr(plr)
        end
        -- Future players
        _UWB_playerAddedConn   = _UWB_Players.PlayerAdded:Connect(_UWB_hookPlr)
        _UWB_playerRemovingConn = _UWB_Players.PlayerRemoving:Connect(_UWB_unhookPlr)
        -- Hide own HRP on respawn
        _UWB_charAddedConn = _UWB_nih.CharacterAdded:Connect(function()
            task.wait(0.1)
            _UWB_hideMyHRP()
        end)
        _UWB_hideMyHRP()
        -- Heartbeat enforcement loop
        _UWB_heartbeat = _UWB_RunService.Heartbeat:Connect(function()
            if not _UWB_enabled then return end
            for _, plr in ipairs(_UWB_Players:GetPlayers()) do
                if plr ~= _UWB_nih then
                    _UWB_smack(plr)
                end
            end
            _UWB_hideMyHRP()
        end)
        -- Teleport to Neutral Spawn
        local lp = _UWB_nih
        local char = lp.Character or lp.CharacterAdded:Wait()
        local hrp  = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(Vector3.new(886.599, 39.590, 2353.903))
        end
    end

    local function _UWB_disable()
        if _UWB_heartbeat     then _UWB_heartbeat:Disconnect();          _UWB_heartbeat = nil          end
        if _UWB_playerAddedConn   then _UWB_playerAddedConn:Disconnect();   _UWB_playerAddedConn = nil   end
        if _UWB_playerRemovingConn then _UWB_playerRemovingConn:Disconnect(); _UWB_playerRemovingConn = nil end
        if _UWB_charAddedConn then _UWB_charAddedConn:Disconnect();      _UWB_charAddedConn = nil      end
        -- Restore all expanded hitboxes
        for _, plr in ipairs(_UWB_Players:GetPlayers()) do
            _UWB_unhookPlr(plr)
        end
        _UWB_stash = {}
        _UWB_plugs = {}
        -- Restore own HRP visibility
        local char = _UWB_nih.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.Transparency = 1  -- HRP is always invisible on client anyway
                hrp.LocalTransparencyModifier = 1
            end
        end
    end

    UtilityTab:Toggle({
        Title = "Underground Wallbang",
        Desc = "Teleports you to Neutral Spawn and expands all player hitboxes so you can shoot through walls.",
        Value = false,
        Callback = function(v)
            _UWB_enabled = v
            if v then
                task.spawn(function() pcall(_UWB_enable) end)
            else
                task.spawn(function() pcall(_UWB_disable) end)
            end
        end,
    })
end
