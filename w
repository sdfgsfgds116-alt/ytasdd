		-- NEW FEATURE: ChartBar  (horizontal mini bar chart)
		-- Usage: Tab:ChartBar({ Title="Scores", Data={Alice=80, Bob=55, Carol=95} })
		-- Returns { SetData, SetTitle, SetVisible, Animate }
		-- ═══════════════════════════════════════════════════════════════════
		function Func:ChartBar(p)
			local Title   = p.Title    or 'Chart'
			local Data    = p.Data     or {}
			local MaxVal  = p.Max      or nil
			local BarH    = p.BarH     or 14
			local Accent  = p.Color    or nil  -- nil = use theme main color

			local RealBg = Instance.new("Frame", ScrollingFrame_1)
			RealBg.Name = "Real Background"
			RealBg.BackgroundTransparency = 1
			RealBg.BorderSizePixel = 0
			RealBg.Size = UDim2.new(1, 0, 0, 60)
			RealBg.ClipsDescendants = true

			local Bg = Instance.new("Frame", RealBg)
			Bg.Name = "Background"
			Bg.BackgroundColor3 = Color3.fromRGB(29, 28, 38)
			Bg.BorderSizePixel = 0
			Bg.Size = UDim2.new(1, 0, 1, 0)
			addToTheme('Function.Label.Background', Bg)
			Instance.new("UICorner", Bg)

			local Pad = Instance.new("UIPadding", Bg)
			Pad.PaddingLeft = UDim.new(0, 10); Pad.PaddingRight = UDim.new(0, 10)
			Pad.PaddingTop = UDim.new(0, 8); Pad.PaddingBottom = UDim.new(0, 8)

			local OuterLL = Instance.new("UIListLayout", Bg)
			OuterLL.SortOrder = Enum.SortOrder.LayoutOrder
			OuterLL.Padding = UDim.new(0, 5)

			local TitleLbl = Instance.new("TextLabel", Bg)
			TitleLbl.Name = "Title"
			TitleLbl.LayoutOrder = 1
			TitleLbl.Size = UDim2.new(1, 0, 0, 14)
			TitleLbl.BackgroundTransparency = 1
			TitleLbl.BorderSizePixel = 0
			TitleLbl.Font = Enum.Font.GothamBold
			TitleLbl.Text = tostring(Title)
			TitleLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
			TitleLbl.TextSize = 12
			TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
			addToTheme('Text & Icon', TitleLbl)

			local BarsHolder = Instance.new("Frame", Bg)
			BarsHolder.LayoutOrder = 2
			BarsHolder.BackgroundTransparency = 1
			BarsHolder.BorderSizePixel = 0
			BarsHolder.Size = UDim2.new(1, 0, 0, 0)
			BarsHolder.AutomaticSize = Enum.AutomaticSize.Y

			local BarsLL = Instance.new("UIListLayout", BarsHolder)
			BarsLL.SortOrder = Enum.SortOrder.LayoutOrder
			BarsLL.Padding = UDim.new(0, 4)

			-- Hue cycling for colorful bars
			local hueStep = 0
			local barRefs = {}

			local function computeMax(d)
				local m = 0
				for _, v in pairs(d) do
					if type(v) == "number" and v > m then m = v end
				end
				return m
			end

			local function renderBars(d)
				for _, c in pairs(BarsHolder:GetChildren()) do
					if c:IsA("Frame") then c:Destroy() end
				end
				barRefs = {}
				local maxV = MaxVal or computeMax(d)
				if maxV == 0 then maxV = 1 end
				local idx = 0
				for label, val in pairs(d) do
					idx = idx + 1
					local barColor = Accent or Color3.fromHSV((idx * 0.13) % 1, 0.75, 0.9)
					local RowF = Instance.new("Frame", BarsHolder)
					RowF.BackgroundTransparency = 1
					RowF.BorderSizePixel = 0
					RowF.Size = UDim2.new(1, 0, 0, BarH + 2)
					RowF.LayoutOrder = idx
					local RowLL = Instance.new("UIListLayout", RowF)
					RowLL.FillDirection = Enum.FillDirection.Horizontal
					RowLL.VerticalAlignment = Enum.VerticalAlignment.Center
					RowLL.SortOrder = Enum.SortOrder.LayoutOrder
					RowLL.Padding = UDim.new(0, 6)

					local KeyL = Instance.new("TextLabel", RowF)
					KeyL.Size = UDim2.new(0, 52, 1, 0)
					KeyL.LayoutOrder = 1
					KeyL.BackgroundTransparency = 1
					KeyL.BorderSizePixel = 0
					KeyL.Font = Enum.Font.Gotham
					KeyL.Text = tostring(label)
					KeyL.TextColor3 = Color3.fromRGB(255, 255, 255)
					KeyL.TextTransparency = 0.3
					KeyL.TextSize = 10
					KeyL.TextXAlignment = Enum.TextXAlignment.Left
					KeyL.TextTruncate = Enum.TextTruncate.AtEnd
					addToTheme('Text & Icon', KeyL)

					local TrackF = Instance.new("Frame", RowF)
					TrackF.Size = UDim2.new(1, -100, 0, BarH)
					TrackF.LayoutOrder = 2
					TrackF.BackgroundColor3 = Color3.fromRGB(35, 33, 50)
					TrackF.BorderSizePixel = 0
					addToTheme('Function.Slider.Slider Bar', TrackF)
					Instance.new("UICorner", TrackF).CornerRadius = UDim.new(1, 0)
					local TrackPad = Instance.new("UIPadding", TrackF)
					TrackPad.PaddingLeft = UDim.new(0, 2); TrackPad.PaddingRight = UDim.new(0, 2)
					TrackPad.PaddingTop = UDim.new(0, 2); TrackPad.PaddingBottom = UDim.new(0, 2)

					local FillF = Instance.new("Frame", TrackF)
					FillF.AnchorPoint = Vector2.new(0, 0.5)
					FillF.BackgroundColor3 = barColor
					FillF.BorderSizePixel = 0
					FillF.Position = UDim2.new(0, 0, 0.5, 0)
					FillF.Size = UDim2.new(0, 0, 1, 0)
					Instance.new("UICorner", FillF).CornerRadius = UDim.new(1, 0)

					local ValL = Instance.new("TextLabel", RowF)
					ValL.Size = UDim2.new(0, 34, 1, 0)
					ValL.LayoutOrder = 3
					ValL.BackgroundTransparency = 1
					ValL.BorderSizePixel = 0
					ValL.Font = Enum.Font.GothamBold
					ValL.Text = tostring(val)
					ValL.TextColor3 = barColor
					ValL.TextSize = 10
					ValL.TextXAlignment = Enum.TextXAlignment.Right
					ValL.TextTruncate = Enum.TextTruncate.AtEnd

					barRefs[tostring(label)] = { fill = FillF, val = ValL, track = TrackF, color = barColor }

					-- Animate bar fill in
					local ratio = math.clamp(type(val) == "number" and val / maxV or 0, 0, 1)
					task.spawn(function()
						task.wait(0.05 * idx)
						tw({v = FillF, t = 0.35, s = Enum.EasingStyle.Exponential, d = "Out",
							g = {Size = UDim2.new(math.max(ratio, 0.02), 0, 1, 0)}}):Play()
					end)
				end

				task.defer(function()
					local h = BarsLL.AbsoluteContentSize.Y + OuterLL.AbsoluteContentSize.Y + 20
					RealBg.Size = UDim2.new(1, 0, 0, h)
					Bg.Size = UDim2.new(1, 0, 0, h)
				end)
			end

			renderBars(Data)
			BarsLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				task.defer(function()
					local h = OuterLL.AbsoluteContentSize.Y + 20
					RealBg.Size = UDim2.new(1, 0, 0, h)
					Bg.Size = UDim2.new(1, 0, 0, h)
				end)
			end)

			local New = {}
			function New:SetData(d)
				Data = d
				renderBars(d)
			end
			function New:SetTitle(t) TitleLbl.Text = t end
			function New:SetVisible(t) RealBg.Visible = t end
			function New:Animate()
				local maxV = MaxVal or computeMax(Data)
				if maxV == 0 then maxV = 1 end
				for label, refs in pairs(barRefs) do
					local v = Data[label]
					if type(v) == "number" then
						local ratio = math.clamp(v / maxV, 0, 1)
						tw({v = refs.fill, t = 0.4, s = Enum.EasingStyle.Exponential, d = "Out",
							g = {Size = UDim2.new(math.max(ratio, 0.02), 0, 1, 0)}}):Play()
					end
				end
			end
			return New
		end

