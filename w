-- Chat-specific color palette (extends CNC_* already in scope)
local CL_SELF_NAME  = Color3.fromRGB(120, 200, 255)   -- local player: sky blue
local CL_OTHER_NAME = Color3.fromRGB(255, 200,  60)   -- other players: gold
