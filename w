CT.StartCarShield = function()
    if CT.shieldConn then CT.shieldConn:Disconnect(); CT.shieldConn = nil end
    CT.shieldEnabled = true
    CT.shieldAngle   = 0
    local myChar = LocalPlayer.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then CT.Notif("Car Shield", "Character not ready"); CT.shieldEnabled = false; return end
    local bestVehicle = CT.FindNearestVehicle(false)
    if not bestVehicle then CT.Notif("Car Shield", "No free vehicle nearby"); CT.shieldEnabled = false; return end
    local root = CT.GetVehicleRoot(bestVehicle)
    if not root then CT.Notif("Car Shield", "No root part"); CT.shieldEnabled = false; return end
    CT.Notif("Car Shield", "Shield active — car orbiting you")
    CT.shieldConn = RunService.Heartbeat:Connect(function(dt)
        if not CT.shieldEnabled then return end
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or not root.Parent then CT.shieldEnabled = false; return end
        CT.shieldAngle = (CT.shieldAngle + dt * CT.shieldSpeed) % 360
        local rad = math.rad(CT.shieldAngle)
        local offset = Vector3.new(
            math.cos(rad) * CT.shieldRadius,
            CT.shieldHeight,
            math.sin(rad) * CT.shieldRadius
        )
        local targetCF = CFrame.new(hrp.Position + offset)
            * CFrame.Angles(0, rad + math.pi / 2, 0)
        pcall(function()
            bestVehicle.PrimaryPart = root
            bestVehicle:SetPrimaryPartCFrame(targetCF)
            for _, p in ipairs(bestVehicle:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.AssemblyLinearVelocity  = Vector3.zero
                    p.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end)
    end)
end

