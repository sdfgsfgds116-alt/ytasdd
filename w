                if state.origCollide[part] == nil then
                    state.origCollide[part] = part.CanCollide
                end
                pcall(function() part.CanCollide = false end)
            end)
        end
    end

    local function restoreParts(char)
        if not char then return end
        for part, oldTrans in pairs(state.origTrans) do
            if part and part.Parent then
                pcall(function() part.LocalTransparencyModifier = oldTrans or 0 end)
            end
        end
        for part, oldCan in pairs(state.origCollide) do
            if part and part.Parent then
                pcall(function() part.CanCollide = oldCan ~= nil and oldCan or true end)
            end
        end
        state.origTrans   = {}
        state.origCollide = {}
    end

    local function enable()
        if state.heartbeat then state.heartbeat:Disconnect(); state.heartbeat = nil end
        pcall(function() RunService:UnbindFromRenderStep("InvisV2CameraFix") end)
        state.active = true

        state.heartbeat = RunService.Heartbeat:Connect(function()
            if not state.active then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            pcall(function()
                hideParts(char)
                -- Always offset from the real above-ground CFrame (state.savedPos),
                -- never from hrp.CFrame directly — which may already be underground
                -- if RenderStep hasn't snapped back yet, causing depth to stack.
                local realPos = state.savedPos or hrp.CFrame
                state.savedPos = realPos
                hrp.CFrame = realPos - Vector3.new(0, 2, 0)
            end)
        end)

        RunService:BindToRenderStep("InvisV2CameraFix", Enum.RenderPriority.Camera.Value - 1, function()
            if not state.active then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if state.savedPos and hrp then
                pcall(function() hrp.CFrame = state.savedPos end)
                state.savedPos = nil
            end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                workspace.CurrentCamera.CameraType    = Enum.CameraType.Custom
                workspace.CurrentCamera.CameraSubject = hum
            end
        end)

        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title    = "Invisibility V2",
            Text     = "Active — underground & invisible. Walk freely.",
            Duration = 3,
        })
    end

    local function disable()
        state.active = false
        if state.heartbeat then state.heartbeat:Disconnect(); state.heartbeat = nil end
        pcall(function() RunService:UnbindFromRenderStep("InvisV2CameraFix") end)
        local char = LocalPlayer.Character
        pcall(function()
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if state.savedPos and hrp then
                    hrp.CFrame = state.savedPos
                    state.savedPos = nil
                end
            end
        end)
        restoreParts(char)
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title    = "Invisibility V2",
            Text     = "Disabled — visibility restored.",
            Duration = 3,
        })
    end

    UtilityTab:Toggle({
        Title = 'Invisibility V2',
        Value = false,
        Callback = function(v)
            if v then enable() else disable() end
        end,
    })

    LocalPlayer.CharacterAdded:Connect(function()
        if state.active then
            task.wait(0.25)
            state.origTrans   = {}
            state.origCollide = {}
            state.savedPos    = nil
        end
    end)
end) -- End of InvisibilityV2 task.spawn wrapper

