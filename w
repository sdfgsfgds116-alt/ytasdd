-- ============================================================================
-- ANTI-AFK IMPLEMENTATION
-- ============================================================================
-- Multi-layered approach:
--   Layer 1 – Proactive: fires small VirtualUser inputs every ~55s so the
--             Idled event (triggered at 60s) never fires in the first place.
--   Layer 2 – Reactive:  if Idled fires anyway (e.g. the interval missed a
--             beat), immediately simulate input to dismiss it.
--   Layer 3 – Camera nudge: slightly rotates the camera each cycle to
--             satisfy games that watch CFrame instead of input state.
--   Layer 4 – Humanoid walk-state ping: briefly sets WalkSpeed to itself so
--             the server sees activity on the character.

local _afkVirtualUser = game:GetService("VirtualUser")
local _afkLastBeat    = tick()
local _afkNudgeDir    = 1  -- alternates ±1 to keep the camera natural

-- Helper: perform one full "simulate active user" cycle
local function _afkSimulateInput()
    pcall(function()
        -- Mouse-button tap (Layer 1 / Layer 2 core)
        _afkVirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        task.wait(0.1)
        _afkVirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)

        -- Camera nudge (Layer 3)
        local cam = workspace.CurrentCamera
        if cam then
            local nudgeAmount = 0.003 * _afkNudgeDir
            _afkNudgeDir = -_afkNudgeDir
            cam.CFrame = cam.CFrame * CFrame.Angles(0, nudgeAmount, 0)
        end

        -- Humanoid walk-state ping (Layer 4)
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                local ws = hum.WalkSpeed
                hum.WalkSpeed = ws
            end
        end
    end)
    _afkLastBeat = tick()
end

-- Layer 1 – proactive heartbeat loop (every 55 seconds)
local _afkLoopThread = task.spawn(function()
    while true do
        task.wait(55)
        if AntiFeatures_Enabled.AntiAFK then
            _afkSimulateInput()
        end
    end
end)

-- Layer 2 – reactive: catch any Idled event that slipped through
AntiFeatures_Connections.AntiAFK = LocalPlayer.Idled:Connect(function()
    if AntiFeatures_Enabled.AntiAFK then
        _afkSimulateInput()
    end
end)

