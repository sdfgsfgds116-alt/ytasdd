        [Enum.KeyCode.D] = Vector3.new( 1, 0,  0),
        [Enum.KeyCode.A] = Vector3.new(-1, 0,  0),
        [Enum.KeyCode.W] = Vector3.new( 0, 0, -1),
        [Enum.KeyCode.S] = Vector3.new( 0, 0,  1),
    }

    local function ME_getChar()
        local c = LocalPlayer.Character
        if not c then return nil, nil, nil end
        local hrp = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        return c, hrp, hum
    end

    local function ME_isInAir(hum)
        return hum and hum.FloorMaterial == Enum.Material.Air
    end

    local function ME_doDash(localDir)
        if not ME_dashEnabled or not ME_canDash then return end
        local _, hrp, hum = ME_getChar()
        if not hrp or not hum or hum.Health <= 0 then return end
        if not ME_isInAir(hum) then return end

        ME_canDash = false
        local worldDir = (hrp.CFrame:VectorToWorldSpace(localDir)).Unit
        local bv = Instance.new("BodyVelocity")
        bv.Velocity = worldDir * ME_dashSpeed
        bv.MaxForce = Vector3.new(1e5, 0, 1e5)
        bv.P        = 1e5
        bv.Parent   = hrp
        task.wait(ME_dashDuration)
        bv:Destroy()
        task.wait(ME_dashCooldown)
        ME_canDash = true
    end

    local function ME_doJumpDash()
        if not ME_jumpDashEnabled or not ME_canJumpDash then return end
        local _, hrp, hum = ME_getChar()
        if not hrp or not hum or hum.Health <= 0 then return end
        if not ME_isInAir(hum) then return end

        ME_canJumpDash = false
        local bv = Instance.new("BodyVelocity")
        bv.Velocity = Vector3.new(0, ME_jumpDashHeight / ME_dashDuration, 0)
        bv.MaxForce = Vector3.new(0, 1e5, 0)
        bv.P        = 1e5
        bv.Parent   = hrp
        task.wait(ME_dashDuration)
        bv:Destroy()
        task.wait(ME_dashCooldown)
        ME_canJumpDash = true
    end

    local function ME_startListeners()
        if ME_dashConn then ME_dashConn:Disconnect() end
        if ME_jumpConn  then ME_jumpConn:Disconnect()  end

        local ME_UIS = game:GetService("UserInputService")

        ME_dashConn = ME_UIS.InputBegan:Connect(function(input, gp)
            if gp then return end
            local dir = ME_keyToDir[input.KeyCode]
            if dir and ME_dashEnabled then
                task.spawn(ME_doDash, dir)
            end
        end)

        ME_jumpConn = ME_UIS.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.KeyCode == Enum.KeyCode.Space and ME_jumpDashEnabled then
                task.spawn(ME_doJumpDash)
            end
        end)
    end

    ME_startListeners()
    -- ─────────────────────────────────────────────────────────────────────────

    _G._EVAnimationOptions=AnimationOptions
    _G._EVAnimationsList=AnimationsList
end -- movement backend scope

