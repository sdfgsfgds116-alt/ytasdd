        if hum.Health <= 0 then return end

        _RTRN_hideMyHRP()
        _RTRN_groundY      = hrp.Position.Y  -- snapshot the spawn-floor Y; heartbeat will snap to this or this-80
        _RTRN_teleportDown = true             -- first move is always downward (underground)
        _RTRN_skidActive   = true
    end

    local function _RTRN_enable()
        _RTRN_skidActive         = false
        _RTRN_cameraCompensation = 0
        _RTRN_teleportDown       = true
        _RTRN_stash              = {}
        _RTRN_plugs              = {}

        -- Expand hitboxes for all current players
        for _, plr in ipairs(_RTRN_Players:GetPlayers()) do
            _RTRN_hookPlr(plr)
        end
        _RTRN_playerAddedConn    = _RTRN_Players.PlayerAdded:Connect(_RTRN_hookPlr)
        _RTRN_playerRemovingConn = _RTRN_Players.PlayerRemoving:Connect(_RTRN_unhookPlr)

        -- Handle own character spawns
        _RTRN_charConn = _RTRN_nih.CharacterAdded:Connect(function(char)
            -- Immediately halt any in-progress oscillation so the heartbeat cannot
            -- fire a stray +80 upward teleport on the freshly-spawned character
            -- before task.spawn gets a chance to run _RTRN_onCharacterSpawned.
            _RTRN_skidActive         = false
            _RTRN_cameraCompensation = 0
            _RTRN_teleportDown       = true
            _RTRN_groundY            = nil  -- clear stale ground Y; will be re-captured after landing
            task.spawn(_RTRN_onCharacterSpawned, char)
        end)
        if _RTRN_nih.Character then
            task.spawn(_RTRN_onCharacterSpawned, _RTRN_nih.Character)
        end

        -- RenderStepped: cancel the bounce but keep camera CAM_UNDERGROUND_OFFSET studs below
        -- normal — this pins the camera underground so shots angle upward through the floor.
        _RTRN_renderStep = _RTRN_RunService.RenderStepped:Connect(function()
            if _RTRN_skidActive then
                local cam = workspace.CurrentCamera
                -- cameraCompensation cancels the teleport bounce.
                -- Subtracting CAM_UNDERGROUND_OFFSET pins the camera underground.
                local totalShift = _RTRN_cameraCompensation - _RTRN_CAM_UNDERGROUND_OFFSET
                if totalShift ~= 0 then
                    cam.CFrame = cam.CFrame + Vector3.new(0, totalShift, 0)
                end
            end
        end)

        -- Heartbeat: enforce hitboxes every frame + drive the rapid Y teleport
        _RTRN_heartbeat = _RTRN_RunService.Heartbeat:Connect(function()
            if not _RTRN_enabled then return end
            local now = tick()
            for _, plr in ipairs(_RTRN_Players:GetPlayers()) do
                if plr ~= _RTRN_nih then
                    _RTRN_smack(plr)
                end
            end
            _RTRN_hideMyHRP()
            if _RTRN_skidActive and (now - _RTRN_lastTeleport) >= _RTRN_TELEPORT_INTERVAL then
                local char = _RTRN_nih.Character
                local hrp  = _RTRN_grabRoot(char)
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                -- Never oscillate a dead or dying character
                if hrp and hum and hum.Health > 0 and _RTRN_groundY then
                    -- Absolute Y snap: always move to exactly groundY (surface) or
                    -- groundY-OFFSET (underground). Using a delta to preserve CFrame
                    -- rotation while forcing Y to the correct absolute level.
                    -- This prevents any drift or above-ground teleport regardless of
                    -- what state teleportDown was left in on a previous character.
                    local targetY = _RTRN_teleportDown
                        and (_RTRN_groundY - _RTRN_TELEPORT_OFFSET)  -- underground
                        or   _RTRN_groundY                            -- back to surface
                    hrp.CFrame = hrp.CFrame + Vector3.new(0, targetY - hrp.Position.Y, 0)
                    -- When HRP is 80 below, compensate 80 so camera only stays
                    -- CAM_UNDERGROUND_OFFSET below normal eye level.
                    -- When HRP is back up, compensate 0 (camera dips by CAM_UNDERGROUND_OFFSET).
                    _RTRN_cameraCompensation = _RTRN_teleportDown and _RTRN_TELEPORT_OFFSET or 0
                    _RTRN_teleportDown = not _RTRN_teleportDown
                    _RTRN_lastTeleport = now
                elseif hum and hum.Health <= 0 then
                    -- Character is dead — halt the oscillation immediately
                    _RTRN_skidActive         = false
                    _RTRN_cameraCompensation = 0
                end
            end
        end)
    end

    local function _RTRN_disable()
        _RTRN_skidActive         = false
        _RTRN_cameraCompensation = 0
        if _RTRN_heartbeat          then _RTRN_heartbeat:Disconnect();          _RTRN_heartbeat = nil          end
        if _RTRN_renderStep         then _RTRN_renderStep:Disconnect();         _RTRN_renderStep = nil         end
        if _RTRN_charConn           then _RTRN_charConn:Disconnect();           _RTRN_charConn = nil           end
        if _RTRN_playerAddedConn    then _RTRN_playerAddedConn:Disconnect();    _RTRN_playerAddedConn = nil    end
        if _RTRN_playerRemovingConn then _RTRN_playerRemovingConn:Disconnect(); _RTRN_playerRemovingConn = nil end
        for _, plr in ipairs(_RTRN_Players:GetPlayers()) do
            _RTRN_unhookPlr(plr)
        end
        _RTRN_stash = {}
        _RTRN_plugs = {}
        -- Restore own HRP visibility
        local char = _RTRN_nih.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.Transparency = 1
                hrp.LocalTransparencyModifier = 1
            end
        end
    end

    UtilityTab:Toggle({
        Title = "Reverse Transmission",
        Desc  = "Like Transmission but keeps your camera 10 studs underground — you look UP through the floor at the bottom of expanded hitboxes, perfect for shooting upward through surfaces.",
        Value = false,
        Callback = function(v)
            _RTRN_enabled = v
            if v then
                task.spawn(function() pcall(_RTRN_enable) end)
            else
                task.spawn(function() pcall(_RTRN_disable) end)
            end
        end,
    })
end
